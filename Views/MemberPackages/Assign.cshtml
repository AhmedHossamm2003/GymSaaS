@model GymSaaS.Models.AssignPackageViewModel
@{
    ViewData["Title"] = Model.MemberName;
    ViewData["Subtitle"] = "Assign Package";
}

@section Styles {
    <style>
        .assign-shell {
            max-width: 780px;
        }

        /* Member strip */
        .member-strip {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 20px;
        }

        .ms-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--fire-soft);
            border: 1.5px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 16px;
            font-weight: 800;
            color: var(--fire-text);
            flex-shrink: 0;
        }

        .ms-name {
            font-size: 14px;
            font-weight: 700;
            color: var(--t1);
        }

        .ms-num {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .1em;
            color: var(--t3);
            margin-top: 2px;
        }

        /* Form card */
        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            overflow: hidden;
            margin-bottom: 16px;
        }

        .form-section-head {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 22px;
            border-bottom: 1px solid var(--border);
            background: var(--surface-2);
        }

        .form-section-icon {
            width: 30px;
            height: 30px;
            border-radius: var(--r-xs);
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--fire);
            flex-shrink: 0;
        }

        .form-section-title {
            font-family: var(--font-display);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t1);
        }

        .form-body {
            padding: 22px;
        }

        .form-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        @@media (max-width: 600px) {
            .form-grid-2 {
                grid-template-columns: 1fr;
            }
        }

        .field-hint {
            font-size: 11.5px;
            color: var(--t3);
            margin-top: 5px;
        }

        .field-error {
            font-size: 11.5px;
            color: var(--red);
            margin-top: 5px;
        }

        /* Package selector cards */
        .pkg-selector {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .pkg-option {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border: 1.5px solid var(--border);
            border-radius: var(--r-md);
            cursor: pointer;
            transition: all .15s;
            background: var(--surface);
        }

            .pkg-option:hover {
                border-color: var(--border-strong);
                background: var(--canvas);
            }

            .pkg-option.selected {
                border-color: var(--fire);
                background: var(--fire-soft);
            }

            .pkg-option input[type=radio] {
                display: none;
            }

        .pkg-opt-icon {
            width: 34px;
            height: 34px;
            border-radius: var(--r-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

            .pkg-opt-icon.SESSION {
                background: var(--fire-soft);
                color: var(--fire);
                border: 1px solid var(--fire-border);
            }

            .pkg-opt-icon.OPEN_GYM {
                background: var(--blue-bg);
                color: var(--blue);
                border: 1px solid var(--blue-border);
            }

            .pkg-opt-icon.COMBINED {
                background: var(--canvas);
                color: var(--t2);
                border: 1px solid var(--border);
            }

        .pkg-opt-info {
            flex: 1;
            min-width: 0;
        }

        .pkg-opt-name {
            font-size: 13.5px;
            font-weight: 700;
            color: var(--t1);
        }

        .pkg-opt-meta {
            font-size: 11.5px;
            color: var(--t2);
            margin-top: 2px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .pkg-opt-badge {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 10px;
            font-weight: 700;
            padding: 1px 7px;
            border-radius: 20px;
            border: 1px solid;
        }

            .pkg-opt-badge.SESSION {
                background: var(--fire-soft);
                color: var(--fire-text);
                border-color: var(--fire-border);
            }

            .pkg-opt-badge.OPEN_GYM {
                background: var(--blue-bg);
                color: var(--blue-text);
                border-color: var(--blue-border);
            }

            .pkg-opt-badge.COMBINED {
                background: var(--canvas);
                color: var(--t2);
                border-color: var(--border);
            }

        .pkg-opt-check {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 2px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
        }

        .pkg-option.selected .pkg-opt-check {
            background: var(--fire);
            border-color: var(--fire);
            color: #fff;
            font-size: 10px;
        }

        /* Dynamic date fields */
        .date-section {
            display: none;
        }

            .date-section.show {
                display: block;
            }

        .combined-sep {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 16px 0 12px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--t3);
        }

            .combined-sep::before, .combined-sep::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        /* Branch section */
        #branchSection {
            display: none;
        }

        .home-branch-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            border-radius: var(--r-sm);
            padding: 7px 12px;
            font-size: 13px;
            font-weight: 700;
            color: var(--fire-text);
            margin-bottom: 14px;
        }

        .branch-section-label {
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t3);
            margin-bottom: 10px;
            margin-top: 4px;
        }

        .branch-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 8px;
        }

        .branch-check {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            cursor: pointer;
            transition: all .12s;
            background: var(--surface);
        }

            .branch-check:hover {
                border-color: var(--border-strong);
                background: var(--canvas);
            }

            .branch-check input[type=checkbox] {
                width: 15px;
                height: 15px;
                accent-color: var(--fire);
                cursor: pointer;
                padding: 0;
            }

            .branch-check span {
                font-size: 13px;
                color: var(--t1);
            }

            .branch-check input:checked ~ span {
                color: var(--fire);
                font-weight: 600;
            }

        .form-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding-top: 4px;
        }
    </style>
}

<!-- Back -->
<div style="margin-bottom:20px;">
    <a asp-controller="Members" asp-action="Details" asp-route-id="@Model.MemberId"
       style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--t2);">
        <i class="bi bi-arrow-left" style="font-size:14px;"></i> Back to Profile
    </a>
</div>

<div class="page-header">
    <div>
        <div class="page-title">Assign Package</div>
        <div class="page-sub">Choose a package and set the dates for this member.</div>
    </div>
</div>

<!-- Member strip -->
<div class="member-strip">
    <div class="ms-avatar">
        @string.Concat(Model.MemberName.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()))
    </div>
    <div>
        <div class="ms-name">@Model.MemberName</div>
        <div class="ms-num">#@Model.MembershipNumber</div>
    </div>
    @if (Model.CurrentPackages.Any())
    {
        <div style="margin-left:auto; display:flex; flex-direction:column; gap:4px; align-items:flex-end;">
            <div style="font-size:10.5px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--t3);">Current Packages</div>
            @foreach (var cp in Model.CurrentPackages.Take(3))
            {
                <div style="font-size:12px; color:var(--t2);">
                    <span style="color:var(--fire);">●</span> @cp.PackageNameSnapshot
                    @if (cp.ValidToDate.HasValue)
                    {
                        <span style="color:var(--t3);">· Exp @cp.ValidToDate.Value.ToString("MMM d")</span>
                    }
                </div>
            }
        </div>
    }
</div>

<form asp-action="Assign" method="post" class="assign-shell" id="assignForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MemberId" />
    <input type="hidden" asp-for="MemberName" />
    <input type="hidden" asp-for="MembershipNumber" />
    <!-- Store member's home branch id and name for display -->
    <input type="hidden" id="homeBranchId" value="@Model.HomeBranchId" />
    <input type="hidden" id="homeBranchName" value="@Model.HomeBranchName" />

    <!-- 1. Select Package -->
    <div class="form-card">
        <div class="form-section-head">
            <div class="form-section-icon"><i class="bi bi-box-seam"></i></div>
            <span class="form-section-title">Select Package</span>
        </div>
        <div class="form-body">
            @if (!Model.AvailablePackages.Any())
            {
                <div style="text-align:center; padding:20px 0; color:var(--t3); font-size:13px;">
                    No active packages in the catalog.
                    <a asp-controller="PackageCatalog" asp-action="Create" style="color:var(--fire);">Create one first.</a>
                </div>
            }
            else
            {
                <div class="pkg-selector">
                    @foreach (var pkg in Model.AvailablePackages)
                    {
                        var meta = pkg.PackageTypeCode switch
                        {
                            "SESSION" => $"{pkg.SessionCount} sessions · {pkg.DurationDays} days validity",
                            "OPEN_GYM" => $"{pkg.DurationDays} days open gym access",
                            "COMBINED" => $"{pkg.SessionCount} sessions ({pkg.DurationDays}d) + gym ({pkg.OpenGymDurationDays}d)",
                            _ => ""
                        };

                        var policyLabel = pkg.BranchAccessPolicy switch
                        {
                            "HOME_ONLY" => "Home branch only",
                            "SELECTED_BRANCHES" => "Home branch + limited other branches",
                            "ALL_BRANCHES" => "All branches",
                            _ => pkg.BranchAccessPolicy
                        };

                        <label class="pkg-option" onclick="selectPackage(this)"
                               data-type="@pkg.PackageTypeCode"
                               data-policy="@pkg.BranchAccessPolicy"
                               data-sessions="@(pkg.SessionCount?.ToString() ?? "")"
                               data-duration="@(pkg.DurationDays?.ToString() ?? "")"
                               data-gym-duration="@(pkg.OpenGymDurationDays?.ToString() ?? "")">
                            <input type="radio" name="PackageDefinitionId" value="@pkg.PackageDefinitionId" />
                            <div class="pkg-opt-icon @pkg.PackageTypeCode">
                                @if (pkg.PackageTypeCode == "SESSION")
                                {
                                    <i class="bi bi-ticket-perforated"></i>
                                }
                                else if (pkg.PackageTypeCode == "OPEN_GYM")
                                {
                                    <i class="bi bi-door-open"></i>
                                }
                                else
                                {
                                    <i class="bi bi-collection"></i>
                                }
                            </div>
                            <div class="pkg-opt-info">
                                <div style="display:flex; align-items:center; gap:7px; margin-bottom:3px;">
                                    <span class="pkg-opt-name">@pkg.PackageName</span>
                                    <span class="pkg-opt-badge @pkg.PackageTypeCode">@pkg.PackageTypeName</span>
                                </div>
                                <div class="pkg-opt-meta">
                                    <span>@meta</span>
                                    <span style="color:var(--t3);">· @policyLabel</span>
                                    @if (pkg.Price.HasValue)
                                    {
                                        <span style="color:var(--fire); font-weight:700;">@pkg.Price.Value.ToString("N0") EGP</span>
                                    }
                                </div>
                            </div>
                            <div class="pkg-opt-check"><i class="bi bi-check"></i></div>
                        </label>
                    }
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState["PackageDefinitionId"]?.Errors.Count > 0)
                {
                    <div class="field-error" style="display:block; margin-top:10px;">Please select a package.</div>
                }
            }
        </div>
    </div>

    <!-- 2. Branch Selection (shown only for SELECTED_BRANCHES) -->
    <div class="form-card" id="branchSection">
        <div class="form-section-head">
            <div class="form-section-icon"><i class="bi bi-building"></i></div>
            <span class="form-section-title">Allowed Branches</span>
        </div>
        <div class="form-body">
            <!-- Home branch always auto-included -->
            <div class="home-branch-badge">
                <i class="bi bi-house-fill"></i>
                <span id="homeBranchDisplay">@Model.HomeBranchName</span>
                <span style="font-size:10px; font-weight:600; opacity:.7;">(Home — always included)</span>
            </div>

            @{
                var otherBranches = Model.AllBranches.Where(b => b.BranchId != Model.HomeBranchId).ToList();
            }

            @if (otherBranches.Any())
            {
                <div class="branch-section-label">Additional branches this member may also access:</div>
                <div class="branch-grid">
                    @foreach (var b in otherBranches)
                    {
                        <label class="branch-check">
                            <input type="checkbox" name="selectedBranchIds" value="@b.BranchId" />
                            <span>@b.BranchName</span>
                        </label>
                    }
                </div>
            }
            else
            {
                <div style="font-size:13px; color:var(--t3); font-style:italic;">
                    No other branches available to add.
                </div>
            }
        </div>
    </div>

    <!-- 3. Dates & Overrides -->
    <div class="form-card">
        <div class="form-section-head">
            <div class="form-section-icon"><i class="bi bi-calendar-range"></i></div>
            <span class="form-section-title">Dates</span>
        </div>
        <div class="form-body">

            <div class="field" style="margin-bottom:16px; max-width:220px;">
                <label class="field-label" asp-for="CustomStartDate">Start Date</label>
                <input asp-for="CustomStartDate" type="date" />
                <div class="field-hint">Defaults to today if not set.</div>
            </div>

            <!-- SESSION date override -->
            <div class="date-section" id="sessionDateSection">
                <div class="field" style="max-width:220px;">
                    <label class="field-label" asp-for="CustomSessionExpiry">Session Expiry Date</label>
                    <input asp-for="CustomSessionExpiry" type="date" />
                    <div class="field-hint">Leave blank to auto-calculate from package duration.</div>
                </div>
            </div>

            <!-- OPEN_GYM date override -->
            <div class="date-section" id="gymDateSection">
                <div class="field" style="max-width:220px;">
                    <label class="field-label" asp-for="CustomOpenGymExpiry">Open Gym Expiry Date</label>
                    <input asp-for="CustomOpenGymExpiry" type="date" />
                    <div class="field-hint">Leave blank to auto-calculate from package duration.</div>
                </div>
            </div>

            <!-- COMBINED date overrides -->
            <div class="date-section" id="combinedDateSection">
                <div class="combined-sep">Sessions Expiry</div>
                <div class="field" style="max-width:220px;">
                    <label class="field-label" asp-for="CustomSessionExpiry">Session Expiry Date</label>
                    <input asp-for="CustomSessionExpiry" type="date" />
                    <div class="field-hint">Leave blank to auto-calculate.</div>
                </div>
                <div class="combined-sep">Open Gym Expiry</div>
                <div class="field" style="max-width:220px;">
                    <label class="field-label" asp-for="CustomOpenGymExpiry">Open Gym Expiry Date</label>
                    <input asp-for="CustomOpenGymExpiry" type="date" />
                    <div class="field-hint">Leave blank to auto-calculate.</div>
                </div>
            </div>

        </div>
    </div>

    <!-- 4. Custom Sessions + Carry-over -->
    <div class="form-card" id="sessionOverrideCard" style="display:none;">
        <div class="form-section-head">
            <div class="form-section-icon"><i class="bi bi-ticket-perforated"></i></div>
            <span class="form-section-title">Session Override</span>
        </div>
        <div class="form-body">
            <div class="form-grid-2">
                <div class="field">
                    <label class="field-label" asp-for="CustomSessionCount">Custom Session Count</label>
                    <input asp-for="CustomSessionCount" type="number" min="1" placeholder="Leave blank to use default" />
                    <div class="field-hint">Override the default session count for this assignment only.</div>
                </div>
                <div class="field">
                    <label class="field-label" asp-for="CarryOverSessions">Carry-over Sessions</label>
                    <input asp-for="CarryOverSessions" type="number" min="0" value="0" />
                    <div class="field-hint">Add unused sessions from a previous package.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- 5. Notes -->
    <div class="form-card">
        <div class="form-section-head">
            <div class="form-section-icon"><i class="bi bi-sticky"></i></div>
            <span class="form-section-title">Notes</span>
        </div>
        <div class="form-body">
            <div class="field">
                <label class="field-label" asp-for="Notes">Internal Notes</label>
                <textarea asp-for="Notes" rows="2"
                          placeholder="Optional note about this assignment..."
                          style="resize:vertical;"></textarea>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="form-footer">
        <a asp-controller="Members" asp-action="Details" asp-route-id="@Model.MemberId"
           class="btn btn-ghost"><i class="bi bi-x"></i> Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg"></i> Assign Package
        </button>
    </div>

</form>

@section Scripts {
    <script>
        function selectPackage(el) {
            // Visual selection
            document.querySelectorAll('.pkg-option').forEach(o => o.classList.remove('selected'));
            el.classList.add('selected');
            el.querySelector('input[type=radio]').checked = true;

            const type   = el.dataset.type;
            const policy = el.dataset.policy;

            // Show/hide date sections
            document.getElementById('sessionDateSection').classList.toggle('show',  type === 'SESSION');
            document.getElementById('gymDateSection').classList.toggle('show',      type === 'OPEN_GYM');
            document.getElementById('combinedDateSection').classList.toggle('show', type === 'COMBINED');

            // Show session override card for session-based packages
            const showSessions = type === 'SESSION' || type === 'COMBINED';
            document.getElementById('sessionOverrideCard').style.display = showSessions ? 'block' : 'none';

            // Show branch section ONLY for SELECTED_BRANCHES
            // Home branch is always auto-included — extra branches shown for selection
            const branchSection = document.getElementById('branchSection');
            if (policy === 'SELECTED_BRANCHES') {
                branchSection.style.display = 'block';
            } else {
                branchSection.style.display = 'none';
                // Uncheck all extra branch checkboxes so they don't accidentally submit
                document.querySelectorAll('[name="selectedBranchIds"]').forEach(cb => cb.checked = false);
            }
        }
    </script>
}
