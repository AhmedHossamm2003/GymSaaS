@model List<GymSaaS.Models.CoachListItem>
@using GymSaaS.Persistence.Entities

@{
    var search    = ViewData["Search"] as string;
    var branchId  = ViewData["BranchId"] as Guid?;
    var branches  = ViewData["Branches"] as List<Branch> ?? new();
    var total     = (int)(ViewData["TotalCount"] ?? 0);
    var active    = (int)(ViewData["ActiveCount"] ?? 0);
}

<!-- Page header -->
<div class="page-header">
    <div>
        <div class="page-title">Coaches</div>
        <div class="page-subtitle">Manage your team of coaches</div>
    </div>
    <a asp-controller="Coaches" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Coach
    </a>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:24px">
    <div class="stat-card highlight">
        <div class="stat-icon"><i class="bi bi-person-badge"></i></div>
        <div>
            <div class="stat-value">@total</div>
            <div class="stat-label">Total Coaches</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        <div>
            <div class="stat-value">@active</div>
            <div class="stat-label">Active</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
        <div>
            <div class="stat-value">@(total - active)</div>
            <div class="stat-label">Inactive</div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom:20px;padding:16px 20px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <div style="flex:1;min-width:200px;display:flex;align-items:center;gap:8px;background:var(--bg-raised);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0 12px">
            <i class="bi bi-search" style="color:var(--text-faint);font-size:13px"></i>
            <input type="text" name="search" value="@search" placeholder="Search by name or specialty…"
                   style="border:none;background:transparent;outline:none;padding:8px 0;font-size:13px;width:100%"/>
        </div>

        <select name="branchId" style="min-width:160px">
            <option value="">All Branches</option>
            @foreach (var b in branches)
            {
                <option value="@b.BranchId" selected="@(branchId == b.BranchId)">@b.BranchName</option>
            }
        </select>

        <button type="submit" class="btn btn-secondary"><i class="bi bi-funnel"></i> Filter</button>
        @if (!string.IsNullOrWhiteSpace(search) || branchId.HasValue)
        {
            <a asp-controller="Coaches" asp-action="Index" class="btn btn-ghost">Clear</a>
        }
    </form>
</div>

<!-- Coach cards -->
@if (!Model.Any())
{
    <div class="card" style="text-align:center;padding:60px 24px">
        <i class="bi bi-person-badge" style="font-size:40px;color:var(--text-faint)"></i>
        <div style="margin-top:12px;color:var(--text-muted);font-size:14px">No coaches found.</div>
        <a asp-controller="Coaches" asp-action="Create" class="btn btn-primary" style="margin-top:16px;display:inline-flex">
            <i class="bi bi-plus-lg"></i> Add First Coach
        </a>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px">
        @foreach (var c in Model)
        {
            <div class="card" style="padding:20px;display:flex;flex-direction:column;gap:16px">

                <!-- Avatar + name -->
                <div style="display:flex;align-items:center;gap:14px">
                    @if (!string.IsNullOrEmpty(c.PhotoUrl))
                    {
                        <img src="@c.PhotoUrl" alt="@c.FullName"
                             style="width:52px;height:52px;border-radius:50%;object-fit:cover;flex-shrink:0"/>
                    }
                    else
                    {
                        <div style="width:52px;height:52px;border-radius:50%;background:var(--orange);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#fff;flex-shrink:0">
                            @c.Initials
                        </div>
                    }
                    <div style="min-width:0">
                        <div style="font-weight:700;font-size:14px;color:var(--black);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@c.FullName</div>
                        <div style="font-size:12px;color:var(--orange);font-weight:600">@c.Specialty</div>
                    </div>
                    <span class="badge @(c.IsActive ? "badge-active" : "badge-inactive")" style="margin-left:auto;flex-shrink:0">
                        @(c.IsActive ? "Active" : "Inactive")
                    </span>
                </div>

                <!-- Info rows -->
                <div style="display:flex;flex-direction:column;gap:6px;font-size:12.5px;color:var(--text-secondary)">
                    <div style="display:flex;align-items:center;gap:8px">
                        <i class="bi bi-building" style="width:14px;color:var(--text-faint)"></i>
                        <span>@c.BranchName</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px">
                        <i class="bi bi-calendar2-week" style="width:14px;color:var(--text-faint)"></i>
                        <span>@c.ClassCount @(c.ClassCount == 1 ? "class" : "classes")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(c.Phone))
                    {
                        <div style="display:flex;align-items:center;gap:8px">
                            <i class="bi bi-telephone" style="width:14px;color:var(--text-faint)"></i>
                            <span>@c.Phone</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(c.Email))
                    {
                        <div style="display:flex;align-items:center;gap:8px;min-width:0">
                            <i class="bi bi-envelope" style="width:14px;color:var(--text-faint);flex-shrink:0"></i>
                            <span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@c.Email</span>
                        </div>
                    }
                </div>

                <!-- Actions -->
                <div style="display:flex;gap:8px;border-top:1px solid var(--border);padding-top:14px">
                    <a asp-controller="Coaches" asp-action="Edit" asp-route-id="@c.CoachId"
                       class="btn btn-secondary" style="flex:1;justify-content:center;font-size:12px">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form asp-controller="Coaches" asp-action="Delete" asp-route-id="@c.CoachId"
                          method="post" onsubmit="return confirm('Remove @c.FullName?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" style="font-size:12px">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>

            </div>
        }
    </div>
}
