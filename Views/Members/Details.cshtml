@model GymSaaS.Models.MemberDetailsViewModel
@{
    ViewData["Title"] = Model.FullName;
    ViewData["Subtitle"] = "Member Profile";
}

@section Styles {
    <style>
        .profile-shell {
            max-width: 900px;
        }

        .profile-hero {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            padding: 24px;
            display: flex;
            align-items: flex-start;
            gap: 22px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .ph-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 26px;
            font-weight: 800;
            background: var(--fire-soft);
            color: var(--fire-text);
        }

            .ph-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

        .ph-info {
            flex: 1;
            min-width: 200px;
        }

        .ph-name {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .02em;
            color: var(--t1);
            line-height: 1;
            margin-bottom: 4px;
        }

        .ph-number {
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: .14em;
            color: var(--t3);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .ph-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 12.5px;
            color: var(--t2);
        }

            .ph-meta span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .ph-meta i {
                font-size: 13px;
                color: var(--t3);
            }

        .ph-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: flex-start;
        }

        .stat-row-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 16px;
        }

        @@media (max-width: 768px) {
            .stat-row-4 {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .s4-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .s4-icon {
            width: 34px;
            height: 34px;
            border-radius: var(--r-sm);
            background: var(--surface-2);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            color: var(--fire);
            flex-shrink: 0;
        }

        .s4-val {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 800;
            color: var(--t1);
            line-height: 1;
        }

        .s4-lbl {
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t3);
            margin-top: 2px;
        }

        .info-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            overflow: hidden;
            margin-bottom: 16px;
        }

        .ic-head {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            background: var(--surface-2);
            justify-content: space-between;
        }

        .ic-head-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ic-head-icon {
            width: 28px;
            height: 28px;
            border-radius: var(--r-xs);
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: var(--fire);
        }

        .ic-head-title {
            font-family: var(--font-display);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t1);
        }

        .ic-body {
            padding: 20px;
        }

        .info-row {
            display: flex;
            align-items: flex-start;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
            gap: 16px;
        }

            .info-row:last-child {
                border-bottom: none;
            }

        .info-key {
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--t3);
            min-width: 150px;
            flex-shrink: 0;
        }

        .info-val {
            font-size: 13.5px;
            color: var(--t1);
            flex: 1;
        }

        .sp-bar {
            height: 6px;
            background: var(--canvas);
            border-radius: 6px;
            overflow: hidden;
        }

        .sp-fill {
            height: 100%;
            border-radius: 6px;
            background: var(--fire);
            transition: width .4s;
        }

            .sp-fill.warn {
                background: var(--yellow);
            }

            .sp-fill.danger {
                background: var(--red);
            }

        .session-pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 700;
            border: 1px solid;
        }

            .session-pill.unlimited {
                background: var(--blue-bg);
                color: var(--blue-text);
                border-color: var(--blue-border);
            }
    </style>
}

<!-- Back -->
<div style="margin-bottom:20px;">
    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--t2);">
        <i class="bi bi-arrow-left" style="font-size:14px;"></i> Back to Members
    </a>
</div>

<div class="profile-shell">

    <!-- Hero -->
    <div class="profile-hero">
        <div class="ph-avatar">
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="@Model.FullName" />
            }
            else
            {
                @Model.Initials
            }
        </div>

        <div class="ph-info">
            <div class="ph-name">@Model.FullName</div>
            <div class="ph-number">#@Model.MembershipNumber</div>
            <div style="margin-bottom:10px;">
                @if (Model.StatusCode == "ACTIVE")
                {
                    <span class="badge badge-active">Active</span>
                }
                else if (Model.StatusCode == "SUSPENDED")
                {
                    <span class="badge badge-inactive">Suspended</span>
                }
                else if (Model.StatusCode == "FROZEN")
                {
                    <span class="badge badge-info">Frozen</span>
                }
                else
                {
                    <span class="badge badge-pending">@Model.StatusName</span>
                }
            </div>
            <div class="ph-meta">
                <span><i class="bi bi-envelope"></i> @Model.Email</span>
                <span><i class="bi bi-telephone"></i> @Model.PhoneNumber</span>
                <span><i class="bi bi-building"></i> @Model.HomeBranchName</span>
                @if (Model.DateOfBirth.HasValue)
                {
                    <span><i class="bi bi-calendar3"></i> @Model.DateOfBirth.Value.ToString("MMM d, yyyy")</span>
                }
            </div>
        </div>

        <div class="ph-actions">
            <a asp-action="Edit" asp-route-id="@Model.MemberId" class="btn btn-secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <div style="position:relative;" id="statusMenu">
                <button type="button" class="btn btn-ghost" style="border:1px solid var(--border);" id="statusMenuBtn">
                    <i class="bi bi-three-dots"></i>
                </button>
                <div id="statusDrop" style="display:none; position:absolute; right:0; top:40px; background:var(--surface); border:1px solid var(--border); border-radius:var(--r-md); box-shadow:var(--sh-md); min-width:160px; z-index:50; overflow:hidden;">
                    <div style="padding:8px 12px; font-size:10.5px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--t3); border-bottom:1px solid var(--border);">Change Status</div>
                    @foreach (var sc in new[] { ("ACTIVE", "Active"), ("SUSPENDED", "Suspend"), ("FROZEN", "Freeze") })
                    {
                        if (sc.Item1 != Model.StatusCode)
                        {
                            <form asp-action="ChangeStatus" asp-route-id="@Model.MemberId" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="statusCode" value="@sc.Item1" />
                                <button type="submit" style="width:100%; padding:9px 14px; background:none; border:none; text-align:left; font-size:13px; color:var(--t1); cursor:pointer;">
                                    @sc.Item2
                                </button>
                            </form>
                        }
                    }
                    <div style="border-top:1px solid var(--border);">
                        <form asp-action="Delete" asp-route-id="@Model.MemberId" method="post"
                              onsubmit="return confirm('Remove this member? This cannot be undone.')">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; padding:9px 14px; background:none; border:none; text-align:left; font-size:13px; color:var(--red); cursor:pointer;">
                                <i class="bi bi-trash"></i> Remove Member
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="stat-row-4">
        <div class="s4-card">
            <div class="s4-icon"><i class="bi bi-calendar-check"></i></div>
            <div><div class="s4-val">@Model.TotalAttendance</div><div class="s4-lbl">Total Check-ins</div></div>
        </div>
        <div class="s4-card">
            <div class="s4-icon"><i class="bi bi-calendar-month"></i></div>
            <div><div class="s4-val">@Model.AttendanceThisMonth</div><div class="s4-lbl">This Month</div></div>
        </div>
        <div class="s4-card">
            <div class="s4-icon" style="background:var(--fire-soft);border-color:var(--fire-border);">
                <i class="bi bi-ticket-perforated" style="color:var(--fire);"></i>
            </div>
            <div>
                <div class="s4-val" style="color:var(--fire);">@(Model.TotalSessionsRemaining?.ToString() ?? "\u2014")</div>
                <div class="s4-lbl">Sessions Left</div>
            </div>
        </div>
        <div class="s4-card">
            <div class="s4-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <div class="s4-val" style="font-size:16px;">@(Model.LastCheckIn.HasValue ? Model.LastCheckIn.Value.ToString("MMM d") : "\u2014")</div>
                <div class="s4-lbl">Last Check-in</div>
            </div>
        </div>
    </div>

    <!-- Active Packages -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-ticket-perforated"></i></div>
                <span class="ic-head-title">Active Packages</span>
            </div>
            <a asp-controller="MemberPackages" asp-action="Assign" asp-route-memberId="@Model.MemberId"
               class="btn btn-primary" style="padding:5px 12px; font-size:12px;">
                <i class="bi bi-plus-lg"></i> Assign Package
            </a>
        </div>
        <div class="ic-body" style="padding:0;">
            @if (!Model.PackageGroups.Any())
            {
                <div style="text-align:center; padding:28px 0; color:var(--t3); font-size:13px;">
                    <i class="bi bi-ticket-perforated" style="font-size:28px; display:block; margin-bottom:8px; color:var(--yellow);"></i>
                    No active packages. Assign one to allow check-ins.
                </div>
            }
            else
            {
                @foreach (var group in Model.PackageGroups)
                {
                    <div style="border-bottom:1px solid var(--border); padding:16px 20px;">

                        @if (group.IsCombined)
                        {
                            <div style="display:flex; align-items:center; gap:6px; margin-bottom:12px;">
                                <span style="font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--t3);">Combined Package</span>
                                <span class="badge badge-fire" style="font-size:10px;">@group.GroupName</span>
                            </div>
                        }

                        @foreach (var comp in group.Components)
                        {
                            @* Use PackageComponentRole and PackageTypeCode — no .IsSessionBased shortcut *@
                            bool isSession = comp.PackageComponentRole == "SESSION" || comp.PackageTypeCode == "SESSION";

                            <div style="display:flex; align-items:center; gap:14px; margin-bottom:10px; flex-wrap:wrap;">

                                <div style="display:flex; align-items:center; gap:7px; min-width:140px;">
                                    @if (isSession)
                                    {
                                        <div style="width:28px; height:28px; border-radius:var(--r-xs); background:var(--fire-soft); border:1px solid var(--fire-border); display:flex; align-items:center; justify-content:center; font-size:13px; color:var(--fire); flex-shrink:0;">
                                            <i class="bi bi-ticket-perforated"></i>
                                        </div>
                                        <span style="font-size:13px; font-weight:600; color:var(--t1);">
                                            @(group.IsCombined ? "Sessions" : comp.PackageNameSnapshot)
                                        </span>
                                    }
                                    else
                                    {
                                        <div style="width:28px; height:28px; border-radius:var(--r-xs); background:var(--blue-bg); border:1px solid var(--blue-border); display:flex; align-items:center; justify-content:center; font-size:13px; color:var(--blue); flex-shrink:0;">
                                            <i class="bi bi-door-open"></i>
                                        </div>
                                        <span style="font-size:13px; font-weight:600; color:var(--t1);">
                                            @(group.IsCombined ? "Open Gym" : comp.PackageNameSnapshot)
                                        </span>
                                    }
                                </div>

                                <div style="font-size:12px; color:var(--t2); flex:1;">
                                    <i class="bi bi-calendar-event" style="font-size:11px; margin-right:3px;"></i>
                                    @comp.ValidFromDate.ToString("MMM d, yyyy")
                                    @if (comp.ValidToDate.HasValue)
                                    {
                                        <span style="margin:0 4px;">&#8594;</span>
                                        bool expd = comp.ValidToDate.Value < DateOnly.FromDateTime(DateTime.UtcNow);
                                        bool soon = !expd && comp.ValidToDate.Value <= DateOnly.FromDateTime(DateTime.UtcNow.AddDays(7));
                                        <span style="color:@(expd ? "var(--red)" : soon ? "var(--yellow)" : "var(--t2)")">
                                            @comp.ValidToDate.Value.ToString("MMM d, yyyy")
                                            @if (expd)
                                            {
                                                <span> (Expired)</span>
                                            }
                                            else if (soon)
                                            {
                                                <span> (Soon)</span>
                                            }
                                        </span>
                                    }
                                </div>

                                @if (isSession && comp.SessionCountOriginal.HasValue)
                                {
                                    int rem = comp.SessionCountRemaining ?? 0;
                                    int orig = comp.SessionCountOriginal.Value;
                                    int pct = orig > 0 ? Math.Min(100, (int)((double)rem / orig * 100)) : 0;
                                    string barCls = rem <= 2 ? "danger" : rem <= 5 ? "warn" : "";
                                    <div style="min-width:160px; flex:1;">
                                        <div style="display:flex; justify-content:space-between; font-size:11.5px; font-weight:600; color:var(--t3); margin-bottom:4px;">
                                            <span>Sessions</span>
                                            <span style="color:@(rem <= 2 ? "var(--red)" : "var(--t1)")">@rem / @orig</span>
                                        </div>
                                        <div class="sp-bar"><div class="sp-fill @barCls" style="width:@pct%"></div></div>
                                    </div>
                                }

                                @if (!isSession)
                                {
                                    <span class="session-pill unlimited">
                                        <i class="bi bi-infinity" style="font-size:10px;"></i> Daily Access
                                    </span>
                                }

                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- Personal Info -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-person-lines-fill"></i></div>
                <span class="ic-head-title">Personal Information</span>
            </div>
        </div>
        <div class="ic-body">
            <div class="info-row"><span class="info-key">Full Name</span><span class="info-val">@Model.FullName</span></div>
            <div class="info-row"><span class="info-key">Email</span><span class="info-val"><a href="mailto:@Model.Email" style="color:var(--fire);">@Model.Email</a></span></div>
            <div class="info-row"><span class="info-key">Phone</span><span class="info-val"><a href="tel:@Model.PhoneNumber" style="color:var(--fire);">@Model.PhoneNumber</a></span></div>
            <div class="info-row"><span class="info-key">Gender</span><span class="info-val">@(Model.Gender ?? "\u2014")</span></div>
            <div class="info-row"><span class="info-key">Date of Birth</span><span class="info-val">@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("MMMM d, yyyy") : "\u2014")</span></div>
            <div class="info-row"><span class="info-key">Home Branch</span><span class="info-val">@Model.HomeBranchName</span></div>
            @if (!string.IsNullOrWhiteSpace(Model.EmergencyContactName))
            {
                <div class="info-row"><span class="info-key">Emergency</span><span class="info-val">@Model.EmergencyContactName — @(Model.EmergencyContactPhone ?? "\u2014")</span></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div class="info-row"><span class="info-key">Notes</span><span class="info-val" style="white-space:pre-wrap;">@Model.Notes</span></div>
            }
        </div>
    </div>

    <!-- Account -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-shield-check"></i></div>
                <span class="ic-head-title">Account</span>
            </div>
        </div>
        <div class="ic-body">
            <div class="info-row"><span class="info-key">Membership #</span><span class="info-val" style="font-family:monospace; font-weight:700;">@Model.MembershipNumber</span></div>
            <div class="info-row"><span class="info-key">Registered</span><span class="info-val">@Model.CreatedAtUtc.ToString("MMMM d, yyyy")</span></div>
            <div class="info-row"><span class="info-key">Last App Login</span><span class="info-val">@(Model.LastLoginAtUtc.HasValue ? Model.LastLoginAtUtc.Value.ToString("MMM d, yyyy") + " UTC" : "Never")</span></div>
            <div class="info-row"><span class="info-key">Last Check-in</span><span class="info-val">@(Model.LastCheckIn.HasValue ? Model.LastCheckIn.Value.ToString("MMM d, yyyy") + " UTC" : "Never")</span></div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById("statusMenuBtn")?.addEventListener("click", function(e) {
            e.stopPropagation();
            const drop = document.getElementById("statusDrop");
            drop.style.display = drop.style.display === "none" ? "block" : "none";
        });
        document.addEventListener("click", function() {
            const drop = document.getElementById("statusDrop");
            if (drop) drop.style.display = "none";
        });
    </script>
}
