@model GymSaaS.Models.MemberDetailsViewModel
@{
    ViewData["Title"] = Model.FullName;
    ViewData["Subtitle"] = "Member Profile";
}

@section Styles {
    <style>
        .profile-shell {
            max-width: 900px;
        }

        .profile-hero {
            background: linear-gradient(135deg, #ffffff 0%, #fbfbfd 100%);
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: 18px;
            box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 6px 20px rgba(15,23,42,0.05);
            padding: 26px;
            display: flex;
            align-items: flex-start;
            gap: 22px;
            margin-bottom: 18px;
            flex-wrap: wrap;
            position: relative;
            overflow: hidden;
        }

            .profile-hero::before {
                content: '';
                position: absolute;
                top: 0;
                left: 24px;
                right: 24px;
                height: 2px;
                background: linear-gradient(90deg, var(--fire, #f97316), #fdba74, transparent);
                border-radius: 0 0 2px 2px;
            }

        .ph-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-size: 26px;
            font-weight: 800;
            background: var(--fire-soft);
            color: var(--fire-text);
        }

            .ph-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

        .ph-info {
            flex: 1;
            min-width: 200px;
        }

        .ph-name {
            font-family: var(--font-display);
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .02em;
            color: var(--t1);
            line-height: 1;
            margin-bottom: 4px;
        }

        .ph-number {
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: .14em;
            color: var(--t3);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .ph-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 12.5px;
            color: var(--t2);
        }

            .ph-meta span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .ph-meta i {
                font-size: 13px;
                color: var(--t3);
            }

        .ph-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: flex-start;
        }

        .stat-row-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 16px;
        }

        @@media (max-width: 768px) {
            .stat-row-4 {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .s4-card {
            background: #ffffff;
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: 16px;
            box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
            position: relative;
            overflow: hidden;
        }

            .s4-card::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.9), transparent);
                pointer-events: none;
            }

            .s4-card:hover {
                box-shadow: 0 4px 8px rgba(15,23,42,0.05), 0 12px 28px rgba(15,23,42,0.08);
                border-color: rgba(15,23,42,0.10);
                transform: translateY(-2px);
            }

        .s4-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, #fafafa, #f4f4f5);
            border: 1px solid rgba(15,23,42,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            color: var(--fire);
            flex-shrink: 0;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
        }

        .s4-val {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 800;
            color: var(--t1);
            line-height: 1;
        }

        .s4-lbl {
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t3);
            margin-top: 2px;
        }

        .info-card {
            background: #ffffff;
            border: 1px solid rgba(15,23,42,0.06);
            border-radius: 16px;
            box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
            overflow: hidden;
            margin-bottom: 18px;
            transition: box-shadow 0.25s ease, border-color 0.25s ease;
        }

            .info-card:hover {
                box-shadow: 0 2px 4px rgba(15,23,42,0.05), 0 8px 24px rgba(15,23,42,0.06);
                border-color: rgba(15,23,42,0.09);
            }

        .ic-head {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            border-bottom: 1px solid rgba(15,23,42,0.05);
            background: linear-gradient(to bottom, #fafafa, #f5f5f7);
            justify-content: space-between;
        }

        .ic-head-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ic-head-icon {
            width: 28px;
            height: 28px;
            border-radius: var(--r-xs);
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: var(--fire);
        }

        .ic-head-title {
            font-family: var(--font-display);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t1);
        }

        .ic-body {
            padding: 20px;
        }

        .info-row {
            display: flex;
            align-items: flex-start;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
            gap: 16px;
        }

            .info-row:last-child {
                border-bottom: none;
            }

        .info-key {
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--t3);
            min-width: 150px;
            flex-shrink: 0;
        }

        .info-val {
            font-size: 13.5px;
            color: var(--t1);
            flex: 1;
        }

        .sp-bar {
            height: 6px;
            background: var(--canvas);
            border-radius: 6px;
            overflow: hidden;
        }

        .sp-fill {
            height: 100%;
            border-radius: 6px;
            background: var(--fire);
            transition: width .4s;
        }

            .sp-fill.warn {
                background: var(--yellow);
            }

            .sp-fill.danger {
                background: var(--red);
            }

        .session-pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 700;
            border: 1px solid;
        }

            .session-pill.unlimited {
                background: var(--blue-bg);
                color: var(--blue-text);
                border-color: var(--blue-border);
            }
    </style>
}

<!-- Back -->
<div style="margin-bottom:20px;">
    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--t2);">
        <i class="bi bi-arrow-left" style="font-size:14px;"></i> Back to Members
    </a>
</div>

<div class="profile-shell">

    <!-- Hero -->
    <div class="profile-hero">
        <div class="ph-avatar">
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="@Model.FullName" />
            }
            else
            {
                @Model.Initials
            }
        </div>

        <div class="ph-info">
            <div class="ph-name">@Model.FullName</div>
            <div class="ph-number">#@Model.MembershipNumber</div>
            <div style="margin-bottom:10px;">
                @if (Model.StatusCode == "ACTIVE")
                {
                    <span class="badge badge-active">Active</span>
                }
                else if (Model.StatusCode == "SUSPENDED")
                {
                    <span class="badge badge-inactive">Suspended</span>
                }
                else if (Model.StatusCode == "FROZEN")
                {
                    <span class="badge badge-info">Frozen</span>
                }
                else
                {
                    <span class="badge badge-pending">@Model.StatusName</span>
                }
            </div>
            <div class="ph-meta">
                <span><i class="bi bi-envelope"></i> @Model.Email</span>
                <span><i class="bi bi-telephone"></i> @Model.PhoneNumber</span>
                <span><i class="bi bi-building"></i> @Model.HomeBranchName</span>
                @if (Model.DateOfBirth.HasValue)
                {
                    <span><i class="bi bi-calendar3"></i> @Model.DateOfBirth.Value.ToString("MMM d, yyyy")</span>
                }
            </div>
        </div>

        <div class="ph-actions">
            <a asp-action="Edit" asp-route-id="@Model.MemberId" class="btn btn-secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <div style="position:relative;" id="statusMenu">
                <button type="button" class="btn btn-ghost" style="border:1px solid var(--border);" id="statusMenuBtn">
                    <i class="bi bi-three-dots"></i>
                </button>
                <div id="statusDrop" style="display:none; position:absolute; right:0; top:40px; background:var(--surface); border:1px solid var(--border); border-radius:var(--r-md); box-shadow:var(--sh-md); min-width:160px; z-index:50; overflow:hidden;">
                    <div style="padding:8px 12px; font-size:10.5px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--t3); border-bottom:1px solid var(--border);">Change Status</div>
                    @foreach (var sc in new[] { ("ACTIVE", "Active"), ("SUSPENDED", "Suspend"), ("FROZEN", "Freeze") })
                    {
                        if (sc.Item1 != Model.StatusCode)
                        {
                            <form asp-action="ChangeStatus" asp-route-id="@Model.MemberId" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="statusCode" value="@sc.Item1" />
                                <button type="submit" style="width:100%; padding:9px 14px; background:none; border:none; text-align:left; font-size:13px; color:var(--t1); cursor:pointer;">
                                    @sc.Item2
                                </button>
                            </form>
                        }
                    }
                    <div style="border-top:1px solid var(--border);">
                        <form asp-action="Delete" asp-route-id="@Model.MemberId" method="post"
                              onsubmit="return confirm('Remove this member? This cannot be undone.')">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; padding:9px 14px; background:none; border:none; text-align:left; font-size:13px; color:var(--red); cursor:pointer;">
                                <i class="bi bi-trash"></i> Remove Member
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="stat-row-4">
        <div class="s4-card">
            <div class="s4-icon"><i class="bi bi-calendar-check"></i></div>
            <div><div class="s4-val">@Model.TotalAttendance</div><div class="s4-lbl">Total Check-ins</div></div>
        </div>
        <div class="s4-card">
            <div class="s4-icon"><i class="bi bi-calendar-month"></i></div>
            <div><div class="s4-val">@Model.AttendanceThisMonth</div><div class="s4-lbl">This Month</div></div>
        </div>
        <div class="s4-card">
            <div class="s4-icon" style="background:var(--fire-soft);border-color:var(--fire-border);">
                <i class="bi bi-ticket-perforated" style="color:var(--fire);"></i>
            </div>
            <div>
                <div class="s4-val" style="color:var(--fire);">@(Model.TotalSessionsRemaining?.ToString() ?? "\u2014")</div>
                <div class="s4-lbl">Sessions Left</div>
            </div>
        </div>
        <div class="s4-card">
            <div class="s4-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <div class="s4-val" style="font-size:16px;">@(Model.LastCheckIn.HasValue ? Model.LastCheckIn.Value.ToString("MMM d") : "\u2014")</div>
                <div class="s4-lbl">Last Check-in</div>
            </div>
        </div>
    </div>

    <!-- Active Packages -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-ticket-perforated"></i></div>
                <span class="ic-head-title">Active Packages</span>
            </div>
            <a asp-controller="MemberPackages" asp-action="Assign" asp-route-memberId="@Model.MemberId"
               class="btn btn-primary" style="padding:5px 12px; font-size:12px;">
                <i class="bi bi-plus-lg"></i> Assign Package
            </a>
        </div>
        <div class="ic-body" style="padding:0;">
            @if (!Model.PackageGroups.Any())
            {
                <div style="text-align:center; padding:28px 0; color:var(--t3); font-size:13px;">
                    <i class="bi bi-ticket-perforated" style="font-size:28px; display:block; margin-bottom:8px; color:var(--yellow);"></i>
                    No active packages. Assign one to allow check-ins.
                </div>
            }
            else
            {
                @foreach (var group in Model.PackageGroups)
                {
                    <div style="border-bottom:1px solid var(--border); padding:16px 20px;">

                        @if (group.IsCombined)
                        {
                            <div style="display:flex; align-items:center; gap:6px; margin-bottom:12px;">
                                <span style="font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--t3);">Combined Package</span>
                                <span class="badge badge-fire" style="font-size:10px;">@group.GroupName</span>
                            </div>
                        }

                        @foreach (var comp in group.Components)
                        {
                            @* Use PackageComponentRole and PackageTypeCode — no .IsSessionBased shortcut *@
                            bool isSession = comp.PackageComponentRole == "SESSION" || comp.PackageTypeCode == "SESSION";

                            <div style="display:flex; align-items:center; gap:14px; margin-bottom:10px; flex-wrap:wrap;">

                                <div style="display:flex; align-items:center; gap:7px; min-width:140px;">
                                    @if (isSession)
                                    {
                                        <div style="width:28px; height:28px; border-radius:var(--r-xs); background:var(--fire-soft); border:1px solid var(--fire-border); display:flex; align-items:center; justify-content:center; font-size:13px; color:var(--fire); flex-shrink:0;">
                                            <i class="bi bi-ticket-perforated"></i>
                                        </div>
                                        <span style="font-size:13px; font-weight:600; color:var(--t1);">
                                            @(group.IsCombined ? "Sessions" : comp.PackageNameSnapshot)
                                        </span>
                                    }
                                    else
                                    {
                                        <div style="width:28px; height:28px; border-radius:var(--r-xs); background:var(--blue-bg); border:1px solid var(--blue-border); display:flex; align-items:center; justify-content:center; font-size:13px; color:var(--blue); flex-shrink:0;">
                                            <i class="bi bi-door-open"></i>
                                        </div>
                                        <span style="font-size:13px; font-weight:600; color:var(--t1);">
                                            @(group.IsCombined ? "Open Gym" : comp.PackageNameSnapshot)
                                        </span>
                                    }
                                </div>

                                <div style="font-size:12px; color:var(--t2); flex:1;">
                                    <i class="bi bi-calendar-event" style="font-size:11px; margin-right:3px;"></i>
                                    @comp.ValidFromDate.ToString("MMM d, yyyy")
                                    @if (comp.ValidToDate.HasValue)
                                    {
                                        <span style="margin:0 4px;">&#8594;</span>
                                        bool expd = comp.ValidToDate.Value < DateOnly.FromDateTime(DateTime.UtcNow);
                                        bool soon = !expd && comp.ValidToDate.Value <= DateOnly.FromDateTime(DateTime.UtcNow.AddDays(7));
                                        <span style="color:@(expd ? "var(--red)" : soon ? "var(--yellow)" : "var(--t2)")">
                                            @comp.ValidToDate.Value.ToString("MMM d, yyyy")
                                            @if (expd)
                                            {
                                                <span> (Expired)</span>
                                            }
                                            else if (soon)
                                            {
                                                <span> (Soon)</span>
                                            }
                                        </span>
                                    }
                                </div>

                                @if (isSession && comp.SessionCountOriginal.HasValue)
                                {
                                    int rem = comp.SessionCountRemaining ?? 0;
                                    int orig = comp.SessionCountOriginal.Value;
                                    int pct = orig > 0 ? Math.Min(100, (int)((double)rem / orig * 100)) : 0;
                                    string barCls = rem <= 2 ? "danger" : rem <= 5 ? "warn" : "";
                                    <div style="min-width:160px; flex:1;">
                                        <div style="display:flex; justify-content:space-between; font-size:11.5px; font-weight:600; color:var(--t3); margin-bottom:4px;">
                                            <span>Sessions</span>
                                            <span style="color:@(rem <= 2 ? "var(--red)" : "var(--t1)")">@rem / @orig</span>
                                        </div>
                                        <div class="sp-bar"><div class="sp-fill @barCls" style="width:@pct%"></div></div>
                                    </div>
                                }

                                @if (!isSession)
                                {
                                    <span class="session-pill unlimited">
                                        <i class="bi bi-infinity" style="font-size:10px;"></i> Daily Access
                                    </span>
                                }

                            </div>

                            @* Perks row — shown once per component that carries perks *@
                            @if (comp.HasPerks)
                            {
                                <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:2px;margin-bottom:6px;padding-left:35px;">

                                    @if (comp.InvitationsTotal > 0)
                                    {
                                        int invRem = comp.InvitationsRemaining ?? 0;
                                        <span style="display:inline-flex;align-items:center;gap:4px;font-size:11.5px;font-weight:600;background:var(--fire-soft);border:1px solid var(--fire-border);color:var(--fire-text);border-radius:20px;padding:2px 9px;">
                                            <i class="bi bi-ticket-detailed" style="font-size:10px;"></i>
                                            @invRem / @comp.InvitationsTotal Invitation@(comp.InvitationsTotal != 1 ? "s" : "")
                                        </span>
                                    }

                                    @if (comp.InBodyTotal > 0)
                                    {
                                        int ibRem = comp.InBodyRemaining ?? 0;
                                        <span style="display:inline-flex;align-items:center;gap:4px;font-size:11.5px;font-weight:600;background:var(--blue-bg);border:1px solid var(--blue-border);color:var(--blue-text);border-radius:20px;padding:2px 9px;">
                                            <i class="bi bi-activity" style="font-size:10px;"></i>
                                            @ibRem / @comp.InBodyTotal InBody
                                        </span>
                                    }

                                    @if (comp.PtSessionsTotal > 0)
                                    {
                                        int ptRem = comp.PtSessionsRemaining ?? 0;
                                        string ptColor = ptRem == 0 ? "var(--red)" : "var(--green)";
                                        <span style="display:inline-flex;align-items:center;gap:4px;font-size:11.5px;font-weight:600;background:var(--surface-2);border:1px solid var(--border);color:var(--t1);border-radius:20px;padding:2px 9px;">
                                            <i class="bi bi-person-arms-up" style="font-size:10px;color:var(--green);"></i>
                                            <span style="color:@ptColor">@ptRem</span> / @comp.PtSessionsTotal PT
                                        </span>
                                    }

                                    @if (comp.FreezeAllowanceDays > 0)
                                    {
                                        int freezeRem = comp.FreezeRemainingDays ?? 0;
                                        if (comp.IsFrozen && comp.FrozenUntilDate.HasValue)
                                        {
                                            <span style="display:inline-flex;align-items:center;gap:4px;font-size:11.5px;font-weight:600;background:var(--blue-bg);border:1px solid var(--blue-border);color:var(--blue-text);border-radius:20px;padding:2px 9px;">
                                                <i class="bi bi-snow" style="font-size:10px;"></i>
                                                Frozen until @comp.FrozenUntilDate.Value.ToString("MMM d")
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="display:inline-flex;align-items:center;gap:4px;font-size:11.5px;font-weight:600;background:var(--surface-2);border:1px solid var(--border);color:var(--t2);border-radius:20px;padding:2px 9px;">
                                                <i class="bi bi-snow" style="font-size:10px;color:var(--blue);"></i>
                                                @freezeRem / @comp.FreezeAllowanceDays d Freeze
                                            </span>
                                        }
                                    }

                                </div>
                            }
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- Invitations -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-ticket-detailed"></i></div>
                <span class="ic-head-title">Invitations</span>
                @if (Model.InvitationsRemaining > 0)
                {
                    <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;background:var(--fire-soft);border:1px solid var(--fire-border);color:var(--fire-text);border-radius:20px;padding:1px 8px;">
                        @Model.InvitationsRemaining remaining
                    </span>
                }
            </div>
            @if (Model.InvitationsRemaining > 0)
            {
                <button type="button" class="btn btn-primary" style="padding:5px 12px;font-size:12px;" onclick="openInviteModal()">
                    <i class="bi bi-plus-lg"></i> Use Invitation
                </button>
            }
        </div>
        <div class="ic-body" style="padding:0;">
            @if (!Model.Invitations.Any())
            {
                <div style="text-align:center;padding:28px 0;color:var(--t3);font-size:13px;">
                    <i class="bi bi-ticket-detailed" style="font-size:28px;display:block;margin-bottom:8px;"></i>
                    No invitations recorded yet.
                </div>
            }
            else
            {
                <table style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--surface-2);font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--t3);">
                            <th style="padding:10px 20px;text-align:left;">Guest</th>
                            <th style="padding:10px 20px;text-align:left;">Phone</th>
                            <th style="padding:10px 20px;text-align:left;">Package</th>
                            <th style="padding:10px 20px;text-align:left;">Date</th>
                            <th style="padding:10px 20px;text-align:left;">Status</th>
                            <th style="padding:10px 20px;text-align:left;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Invitations)
                        {
                            <tr style="border-top:1px solid var(--border);font-size:13px;">
                                <td style="padding:11px 20px;">
                                    <span style="font-weight:600;color:var(--t1);">@inv.GuestName</span>
                                    @if (!string.IsNullOrEmpty(inv.InvitedMemberName))
                                    {
                                        <br /><span style="font-size:11px;color:var(--t3);">Member: @inv.InvitedMemberName</span>
                                    }
                                </td>
                                <td style="padding:11px 20px;color:var(--t2);">@inv.GuestPhone</td>
                                <td style="padding:11px 20px;color:var(--t2);font-size:12px;">@inv.PackageName</td>
                                <td style="padding:11px 20px;color:var(--t3);font-size:12px;">@inv.CreatedAtUtc.ToString("MMM d, yyyy")</td>
                                <td style="padding:11px 20px;">
                                    @if (inv.IsPending)
                                    {
                                        <span class="badge badge-pending">Pending</span>
                                    }
                                    else if (inv.IsUsed)
                                    {
                                        <span class="badge badge-active">Used</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-inactive">Cancelled</span>
                                    }
                                </td>
                                <td style="padding:11px 20px;">
                                    @if (inv.IsPending)
                                    {
                                        <div style="display:flex;gap:6px;">
                                            <form asp-controller="Invitations" asp-action="MarkUsed" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@inv.MemberInvitationId" />
                                                <input type="hidden" name="memberId" value="@Model.MemberId" />
                                                <button type="submit" class="btn btn-ghost" style="font-size:11px;padding:3px 9px;border:1px solid var(--border);" title="Mark as used">
                                                    <i class="bi bi-check-lg"></i> Used
                                                </button>
                                            </form>
                                            <form asp-controller="Invitations" asp-action="Cancel" method="post" style="display:inline;"
                                                  onsubmit="return confirm('Cancel this invitation?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@inv.MemberInvitationId" />
                                                <input type="hidden" name="memberId" value="@Model.MemberId" />
                                                <button type="submit" class="btn btn-ghost" style="font-size:11px;padding:3px 9px;border:1px solid var(--border);color:var(--red);" title="Cancel">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Invite Modal -->
    <div id="inviteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;">
        <div style="background:var(--surface);border-radius:var(--r-lg);box-shadow:var(--sh-lg);width:100%;max-width:440px;margin:16px;overflow:hidden;">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border);background:var(--surface-2);">
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:28px;height:28px;border-radius:var(--r-xs);background:var(--fire-soft);border:1px solid var(--fire-border);display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--fire);">
                        <i class="bi bi-ticket-detailed"></i>
                    </div>
                    <span style="font-family:var(--font-display);font-size:13px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;">Use Invitation</span>
                </div>
                <button type="button" onclick="closeInviteModal()" style="background:none;border:none;cursor:pointer;font-size:18px;color:var(--t3);">&times;</button>
            </div>
            <form asp-controller="Invitations" asp-action="Create" method="post" style="padding:20px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MemberId" value="@Model.MemberId" />

                <!-- Phone search -->
                <div class="form-field" style="margin-bottom:14px;">
                    <label class="form-label">Guest Phone</label>
                    <div style="display:flex;gap:8px;">
                        <input type="text" id="invPhoneInput" name="GuestPhone" class="form-control" placeholder="+20 1xx xxxxxxx"
                               style="flex:1;" oninput="debouncedPhoneSearch(this.value)" />
                        <button type="button" onclick="searchByPhone()" class="btn btn-ghost" style="border:1px solid var(--border);white-space:nowrap;font-size:12px;">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                    <div id="phoneSearchResult" style="margin-top:6px;font-size:12px;"></div>
                </div>

                <!-- Hidden field for matched member id (name attr managed by JS) -->
                <input type="hidden" id="invInvitedMemberId" />

                <!-- Guest name -->
                <div class="form-field" style="margin-bottom:14px;">
                    <label class="form-label">Guest Name</label>
                    <input type="text" id="invGuestName" name="GuestName" class="form-control" placeholder="Full name" />
                </div>

                <!-- Notes -->
                <div class="form-field" style="margin-bottom:20px;">
                    <label class="form-label">Notes <span style="color:var(--t3);font-weight:400;">(optional)</span></label>
                    <input type="text" name="Notes" class="form-control" placeholder="e.g. friend of member" />
                </div>

                <div style="display:flex;gap:8px;justify-content:flex-end;">
                    <button type="button" onclick="closeInviteModal()" class="btn btn-ghost" style="border:1px solid var(--border);">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Record Invitation</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Personal Info -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-person-lines-fill"></i></div>
                <span class="ic-head-title">Personal Information</span>
            </div>
        </div>
        <div class="ic-body">
            <div class="info-row"><span class="info-key">Full Name</span><span class="info-val">@Model.FullName</span></div>
            <div class="info-row"><span class="info-key">Email</span><span class="info-val"><a href="mailto:@Model.Email" style="color:var(--fire);">@Model.Email</a></span></div>
            <div class="info-row"><span class="info-key">Phone</span><span class="info-val"><a href="tel:@Model.PhoneNumber" style="color:var(--fire);">@Model.PhoneNumber</a></span></div>
            <div class="info-row"><span class="info-key">Gender</span><span class="info-val">@(Model.Gender ?? "\u2014")</span></div>
            <div class="info-row"><span class="info-key">Date of Birth</span><span class="info-val">@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("MMMM d, yyyy") : "\u2014")</span></div>
            <div class="info-row"><span class="info-key">Home Branch</span><span class="info-val">@Model.HomeBranchName</span></div>
            @if (!string.IsNullOrWhiteSpace(Model.EmergencyContactName))
            {
                <div class="info-row"><span class="info-key">Emergency</span><span class="info-val">@Model.EmergencyContactName — @(Model.EmergencyContactPhone ?? "\u2014")</span></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div class="info-row"><span class="info-key">Notes</span><span class="info-val" style="white-space:pre-wrap;">@Model.Notes</span></div>
            }
        </div>
    </div>

    <!-- Account -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-left">
                <div class="ic-head-icon"><i class="bi bi-shield-check"></i></div>
                <span class="ic-head-title">Account</span>
            </div>
        </div>
        <div class="ic-body">
            <div class="info-row"><span class="info-key">Membership #</span><span class="info-val" style="font-family:monospace; font-weight:700;">@Model.MembershipNumber</span></div>
            <div class="info-row"><span class="info-key">Registered</span><span class="info-val">@Model.CreatedAtUtc.ToString("MMMM d, yyyy")</span></div>
            <div class="info-row"><span class="info-key">Last App Login</span><span class="info-val">@(Model.LastLoginAtUtc.HasValue ? Model.LastLoginAtUtc.Value.ToString("MMM d, yyyy") + " UTC" : "Never")</span></div>
            <div class="info-row"><span class="info-key">Last Check-in</span><span class="info-val">@(Model.LastCheckIn.HasValue ? Model.LastCheckIn.Value.ToString("MMM d, yyyy") + " UTC" : "Never")</span></div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Status dropdown
        document.getElementById("statusMenuBtn")?.addEventListener("click", function(e) {
            e.stopPropagation();
            const drop = document.getElementById("statusDrop");
            drop.style.display = drop.style.display === "none" ? "block" : "none";
        });
        document.addEventListener("click", function() {
            const drop = document.getElementById("statusDrop");
            if (drop) drop.style.display = "none";
        });

        // ── Invitation Modal ──────────────────────────
        function openInviteModal() {
            document.getElementById("inviteModal").style.display = "flex";
            document.getElementById("invPhoneInput").value = "";
            document.getElementById("invGuestName").value = "";
            clearInvitedMember();
            document.getElementById("phoneSearchResult").innerHTML = "";
            document.getElementById("invPhoneInput").focus();
        }

        function clearInvitedMember() {
            const f = document.getElementById("invInvitedMemberId");
            f.removeAttribute("name");
            f.value = "";
        }

        function setInvitedMember(id) {
            const f = document.getElementById("invInvitedMemberId");
            f.name = "InvitedMemberId";
            f.value = id;
        }

        function closeInviteModal() {
            document.getElementById("inviteModal").style.display = "none";
        }

        document.getElementById("inviteModal")?.addEventListener("click", function(e) {
            if (e.target === this) closeInviteModal();
        });

        // Phone search with debounce
        let searchTimer = null;
        function debouncedPhoneSearch(val) {
            clearTimeout(searchTimer);
            if (val.trim().length < 7) {
                document.getElementById("phoneSearchResult").innerHTML = "";
                document.getElementById("invInvitedMemberId").value = "";
                return;
            }
            searchTimer = setTimeout(() => searchByPhone(), 500);
        }

        async function searchByPhone() {
            const phone = document.getElementById("invPhoneInput").value.trim();
            if (!phone) return;

            const resultEl = document.getElementById("phoneSearchResult");
            resultEl.innerHTML = '<span style="color:var(--t3);">Searching...</span>';

            try {
                const res = await fetch(`/Invitations/SearchMember?phone=${encodeURIComponent(phone)}`);
                const data = await res.json();

                if (data.found) {
                    setInvitedMember(data.memberId);
                    document.getElementById("invGuestName").value = data.name;
                    resultEl.innerHTML = `<span style="color:var(--green);font-weight:600;"><i class="bi bi-check-circle-fill"></i> Member found: ${data.name}</span>`;
                } else {
                    clearInvitedMember();
                    resultEl.innerHTML = '<span style="color:var(--t3);"><i class="bi bi-info-circle"></i> Not a registered member — enter name manually.</span>';
                }
            } catch {
                resultEl.innerHTML = '<span style="color:var(--red);">Search failed. Try again.</span>';
            }
        }
    </script>
}
