@model List<GymSaaS.Models.PackageDefinitionListItem>
@{
    ViewData["Title"] = "Package Catalog";
    var grouped = Model.GroupBy(p => p.PackageTypeCode).OrderBy(g => g.Key).ToList();
}

@section Styles {
    <style>
        /* ── Type group ── */
        .pkg-group {
            margin-bottom: 32px;
        }

        .pkg-group-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }

        .pkg-group-label {
            font-family: var(--font-display);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--t1);
        }

        .pkg-group-count {
            font-size: 11.5px;
            font-weight: 600;
            color: var(--t3);
            background: var(--canvas);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2px 9px;
        }

        /* ── Cards grid — 3 fixed columns on laptop, wraps ── */
        .pkg-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        @@media (max-width: 1100px) {
            .pkg-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 680px) {
            .pkg-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ── Package card ── */
        .pkg-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: box-shadow .2s, transform .2s;
        }

            .pkg-card:hover {
                box-shadow: var(--sh-md);
                transform: translateY(-2px);
            }

            .pkg-card.inactive {
                opacity: .55;
            }

            .pkg-card::before {
                content: '';
                display: block;
                height: 3px;
            }

            .pkg-card.SESSION::before {
                background: var(--fire);
            }

            .pkg-card.OPEN_GYM::before {
                background: var(--blue);
            }

            .pkg-card.COMBINED::before {
                background: linear-gradient(90deg, var(--fire) 50%, var(--blue) 50%);
            }

        .pc-head {
            padding: 16px 18px 12px;
            border-bottom: 1px solid var(--border);
        }

        .pc-type-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .pc-type-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 20px;
            border: 1px solid;
        }

            .pc-type-badge.SESSION {
                background: var(--fire-soft);
                color: var(--fire-text);
                border-color: var(--fire-border);
            }

            .pc-type-badge.OPEN_GYM {
                background: var(--blue-bg);
                color: var(--blue-text);
                border-color: var(--blue-border);
            }

            .pc-type-badge.COMBINED {
                background: linear-gradient(90deg, var(--fire-soft), var(--blue-bg));
                color: var(--t1);
                border-color: var(--border);
            }

        .pc-name {
            font-family: var(--font-display);
            font-size: 17px;
            font-weight: 800;
            letter-spacing: .02em;
            color: var(--t1);
            text-transform: uppercase;
            margin-bottom: 4px;
            line-height: 1.2;
        }

        .pc-desc {
            font-size: 12px;
            color: var(--t2);
            line-height: 1.5;
        }

        /* Stats row */
        .pc-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-bottom: 1px solid var(--border);
        }

        .pc-stat {
            padding: 12px 14px;
            border-right: 1px solid var(--border);
            text-align: center;
        }

            .pc-stat:last-child {
                border-right: none;
            }

        .pc-stat-val {
            font-family: var(--font-display);
            font-size: 20px;
            font-weight: 800;
            color: var(--t1);
            line-height: 1;
        }

        .pc-stat-lbl {
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--t3);
            margin-top: 3px;
        }

        /* Info rows */
        .pc-info {
            padding: 12px 18px;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .pc-info-row {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 12.5px;
            color: var(--t2);
        }

            .pc-info-row i {
                font-size: 12px;
                color: var(--t3);
                width: 14px;
                text-align: center;
            }

        /* Price */
        .pc-price-row {
            display: flex;
            align-items: baseline;
            gap: 5px;
            margin-top: 2px;
        }

        .pc-price-val {
            font-family: var(--font-display);
            font-size: 20px;
            font-weight: 800;
            color: var(--fire);
            line-height: 1;
        }

        .pc-price-currency {
            font-size: 11px;
            font-weight: 700;
            color: var(--t3);
            letter-spacing: .05em;
        }

        /* Footer */
        .pc-foot {
            padding: 10px 14px;
            border-top: 1px solid var(--border);
            background: var(--surface-2);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .pc-members {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: var(--t2);
            font-weight: 500;
        }

        /* Empty state */
        .empty-catalog {
            text-align: center;
            padding: 60px 24px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
        }

        .empty-icon {
            width: 64px;
            height: 64px;
            border-radius: var(--r-lg);
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: var(--fire);
            margin: 0 auto 16px;
        }

        .empty-catalog h3 {
            font-family: var(--font-display);
            font-size: 18px;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--t1);
            margin-bottom: 6px;
        }

        .empty-catalog p {
            font-size: 13px;
            color: var(--t2);
            margin-bottom: 20px;
        }

        /* Type icons */
        .type-icon {
            width: 22px;
            height: 22px;
            border-radius: var(--r-xs);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            flex-shrink: 0;
        }

            .type-icon.SESSION {
                background: var(--fire-soft);
                color: var(--fire);
            }

            .type-icon.OPEN_GYM {
                background: var(--blue-bg);
                color: var(--blue);
            }

            .type-icon.COMBINED {
                background: var(--canvas);
                color: var(--t2);
            }
    </style>
}

<!-- Page header -->
<div class="page-header">
    <div>
        <div class="page-title">Package Catalog</div>
        <div class="page-sub">@Model.Count package@(Model.Count != 1 ? "s" : "") defined</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Package
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-catalog">
        <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
        <h3>No Packages Yet</h3>
        <p>Define the packages your gym offers. Members can then be assigned these packages.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create First Package
        </a>
    </div>
}
else
{
    @foreach (var group in grouped)
    {
        var typeLabel = group.Key switch
        {
            "SESSION" => "Sessions Packages",
            "OPEN_GYM" => "Open Gym Packages",
            "COMBINED" => "Combined Packages",
            _ => group.Key
        };

        var typeIcon = group.Key switch
        {
            "SESSION" => "bi-ticket-perforated",
            "OPEN_GYM" => "bi-door-open",
            "COMBINED" => "bi-collection",
            _ => "bi-box-seam"
        };

        <div class="pkg-group">
            <div class="pkg-group-header">
                <div class="type-icon @group.Key"><i class="bi @typeIcon"></i></div>
                <span class="pkg-group-label">@typeLabel</span>
                <span class="pkg-group-count">@group.Count()</span>
            </div>

            <div class="pkg-grid">
                @foreach (var p in group.OrderBy(x => x.SortOrder).ThenBy(x => x.PackageName))
                {
                    <div class="pkg-card @p.PackageTypeCode @(!p.IsActive ? "inactive" : "")">

                        <!-- Head -->
                        <div class="pc-head">
                            <div class="pc-type-row">
                                <span class="pc-type-badge @p.PackageTypeCode">
                                    <i class="bi @typeIcon"></i>
                                    @p.PackageTypeName
                                </span>
                                @if (!p.IsActive)
                                {
                                    <span class="badge badge-pending">Archived</span>
                                }
                                else
                                {
                                    <span class="badge badge-active">Active</span>
                                }
                            </div>
                            <div class="pc-name">@p.PackageName</div>
                            @if (!string.IsNullOrWhiteSpace(p.Description))
                            {
                                <div class="pc-desc">@p.Description</div>
                            }
                        </div>

                        <!-- Stats -->
                        <div class="pc-stats">
                            @if (p.PackageTypeCode == "SESSION" || p.PackageTypeCode == "COMBINED")
                            {
                                <div class="pc-stat">
                                    <div class="pc-stat-val" style="color:var(--fire);">@(p.SessionCount?.ToString() ?? "—")</div>
                                    <div class="pc-stat-lbl">Sessions</div>
                                </div>
                            }
                            @if (p.PackageTypeCode == "OPEN_GYM")
                            {
                                <div class="pc-stat">
                                    <div class="pc-stat-val" style="color:var(--blue);">@(p.DurationDays?.ToString() ?? "—")</div>
                                    <div class="pc-stat-lbl">Days</div>
                                </div>
                            }
                            @if (p.PackageTypeCode == "SESSION")
                            {
                                <div class="pc-stat">
                                    <div class="pc-stat-val">@(p.DurationDays?.ToString() ?? "—")</div>
                                    <div class="pc-stat-lbl">Valid Days</div>
                                </div>
                            }
                            @if (p.PackageTypeCode == "COMBINED")
                            {
                                <div class="pc-stat">
                                    <div class="pc-stat-val">@(p.DurationDays?.ToString() ?? "—")</div>
                                    <div class="pc-stat-lbl">Sess. Days</div>
                                </div>
                                <div class="pc-stat">
                                    <div class="pc-stat-val" style="color:var(--blue);">@(p.OpenGymDurationDays?.ToString() ?? "—")</div>
                                    <div class="pc-stat-lbl">Gym Days</div>
                                </div>
                            }
                            <div class="pc-stat">
                                <div class="pc-stat-val" style="color:var(--green);">@p.AssignedCount</div>
                                <div class="pc-stat-lbl">Active</div>
                            </div>
                        </div>

                        <!-- Info -->
                        <div class="pc-info">
                            <div class="pc-info-row">
                                @if (p.BranchAccessPolicy == "ALL_BRANCHES")
                                {
                                    <i class="bi bi-globe"></i>

                                    <span>All branches</span>
                                }
                                else if (p.BranchAccessPolicy == "HOME_ONLY")
                                {
                                    <i class="bi bi-house"></i>

                                    <span>Home branch only</span>
                                }
                                else
                                {
                                    <i class="bi bi-buildings"></i>

                                    <span>Home branch + limited other branches</span>
                                }
                            </div>
                            @if (p.Price.HasValue)
                            {
                                <div class="pc-price-row">
                                    <i class="bi bi-cash-coin" style="font-size:13px; color:var(--fire);"></i>
                                    <span class="pc-price-val">@p.Price.Value.ToString("N0")</span>
                                    <span class="pc-price-currency">EGP</span>
                                </div>
                            }
                        </div>

                        <!-- Footer -->
                        <div class="pc-foot">
                            <div class="pc-members">
                                <i class="bi bi-people" style="font-size:12px; color:var(--t3);"></i>
                                @p.AssignedCount active member@(p.AssignedCount != 1 ? "s" : "")
                            </div>
                            <div style="display:flex; gap:6px;">
                                <a asp-action="Edit" asp-route-id="@p.PackageDefinitionId"
                                   class="btn btn-secondary" style="padding:5px 10px; font-size:12px;">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@p.PackageDefinitionId" method="post" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn @(p.IsActive ? "btn-ghost" : "btn-secondary")"
                                            style="padding:5px 10px; font-size:12px;"
                                            onclick="return confirm('@(p.IsActive ? "Archive" : "Restore") this package?')">
                                        <i class="bi bi-@(p.IsActive ? "archive" : "arrow-counterclockwise")"></i>
                                        @(p.IsActive ? "Archive" : "Restore")
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                }
            </div>
        </div>
    }
}
