@model GymSaaS.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <style>
       /* =============================================
       DASHBOARD DESIGN SYSTEM
    ============================================= */
    :root {
        --dash-bg: linear-gradient(180deg, #0b1220 0%, #0f172a 100%);
        --dash-surface: rgba(255, 255, 255, 0.06);
        --dash-surface-strong: rgba(255, 255, 255, 0.1);
        --dash-border: rgba(255, 255, 255, 0.08);
        --dash-border-strong: rgba(255, 255, 255, 0.16);
        --dash-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
        --dash-shadow-lg: 0 24px 70px rgba(0, 0, 0, 0.25);
        --dash-glow: 0 0 0 1px rgba(255, 255, 255, 0.02), 0 12px 30px rgba(251, 146, 60, 0.12);
    }

    /* Optional page background */
    body {
        background:
            radial-gradient(circle at top left, rgba(251, 146, 60, 0.12), transparent 28%),
            radial-gradient(circle at top right, rgba(59, 130, 246, 0.10), transparent 24%),
            linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
    }

    /* =============================================
       GRID
    ============================================= */
    .d-grid {
        display: grid;
        gap: 22px;
    }

    .d-cols-4 {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .d-cols-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .d-cols-5-3 {
        grid-template-columns: 5fr 3fr;
    }

    .d-section {
        margin-top: 26px;
    }

    /* =============================================
       GREETING BAR
    ============================================= */
    .greeting-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        padding: 22px 24px;
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.96));
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: var(--dash-shadow);
        position: relative;
        overflow: hidden;
    }

    .greeting-bar::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at top right, rgba(251, 146, 60, 0.18), transparent 28%),
            radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.10), transparent 24%);
        pointer-events: none;
    }

    .greeting-bar > * {
        position: relative;
        z-index: 1;
    }

    .greeting-bar h1 {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 900;
        letter-spacing: -0.03em;
        color: #fff;
        line-height: 1.1;
        margin: 0;
    }

    .greeting-bar h1 span {
                    color: #dd7d00 !important;
               text-shadow: 0 0 18px rgba(251, 146, 60, 0.18);
    }

    .greeting-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.72);
        margin-top: 8px;
    }

    .greeting-meta i {
        color: var(--fire);
        font-size: 14px;
    }

    .greeting-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    /* Buttons */
    .g-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 18px;
        border-radius: 14px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: 1px solid transparent;
        transition: all 0.22s ease;
        text-decoration: none;
        backdrop-filter: blur(10px);
    }

    .g-btn.primary {
        background: linear-gradient(135deg, var(--fire), #f97316);
        color: #fff;
        box-shadow: 0 10px 24px rgba(251, 146, 60, 0.25);
    }

    .g-btn.primary:hover {
        transform: translateY(-2px);
        filter: brightness(1.05);
        box-shadow: 0 16px 30px rgba(251, 146, 60, 0.32);
    }

    .g-btn.outline {
        background: rgba(255, 255, 255, 0.06);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.10);
    }

    .g-btn.outline:hover {
        background: rgba(255, 255, 255, 0.10);
        border-color: rgba(255, 255, 255, 0.18);
        transform: translateY(-2px);
    }

    /* =============================================
       STAT CARDS
    ============================================= */
    .stat {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.78));
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 22px;
        padding: 22px 22px 20px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
        transition: all 0.22s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(10px);
    }

    .stat::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.22), transparent 60%);
        pointer-events: none;
    }

    .stat:hover {
        border-color: rgba(148, 163, 184, 0.35);
        transform: translateY(-4px);
        box-shadow: var(--dash-shadow-lg);
    }

    .stat-ic {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.28);
    }

    .stat-ic.orange { background: linear-gradient(135deg, #ffedd5, #fed7aa); color: var(--fire); }
    .stat-ic.green  { background: linear-gradient(135deg, #dcfce7, #bbf7d0); color: var(--green); }
    .stat-ic.blue   { background: linear-gradient(135deg, #dbeafe, #bfdbfe); color: var(--blue); }
    .stat-ic.purple { background: linear-gradient(135deg, #f3e8ff, #e9d5ff); color: #9333ea; }
    .stat-ic.red    { background: linear-gradient(135deg, #fee2e2, #fecaca); color: var(--red-text); }

    .stat-body {
        flex: 1;
        position: relative;
        z-index: 1;
    }

    .stat-val {
        font-family: var(--font-display);
        font-size: 34px;
        font-weight: 900;
        color: var(--t1);
        line-height: 1;
        letter-spacing: -0.04em;
    }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--t3);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-top: 6px;
    }

    .stat-accent {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        opacity: 0.95;
    }

    .stat-accent.orange { background: linear-gradient(to right, var(--fire), transparent); }
    .stat-accent.green  { background: linear-gradient(to right, var(--green), transparent); }
    .stat-accent.blue   { background: linear-gradient(to right, var(--blue), transparent); }
    .stat-accent.purple { background: linear-gradient(to right, #9333ea, transparent); }
    .stat-accent.red    { background: linear-gradient(to right, var(--red-text), transparent); }

    /* =============================================
       PANELS
    ============================================= */
    .panel {
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(12px);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .panel:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.10);
    }

    .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px 16px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    }

    .panel-title {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--t1);
    }

    .panel-link {
        font-size: 12px;
        font-weight: 700;
        color: var(--fire);
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .panel-link:hover {
        gap: 7px;
        color: #ea580c;
    }

    .panel-body {
        padding: 20px 24px 24px;
    }

    /* =============================================
       CHART / EMPTY STATES
    ============================================= */
    .chart-wrap {
        position: relative;
        height: 260px;
    }

    .chart-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--t3);
        gap: 10px;
        border: 1px dashed rgba(148, 163, 184, 0.25);
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(248,250,252,0.7), rgba(255,255,255,0.6));
    }

    .chart-empty i {
        font-size: 30px;
        opacity: 0.35;
        color: var(--fire);
    }

    .chart-empty p {
        font-size: 13px;
        max-width: 260px;
        text-align: center;
        line-height: 1.5;
        margin: 0;
    }

    /* =============================================
       ACTIVITY LIST
    ============================================= */
    .activity-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 22px;
        border-top: 1px solid rgba(148, 163, 184, 0.12);
        transition: background 0.15s ease, transform 0.15s ease;
    }

    .activity-item:hover {
        background: rgba(248, 250, 252, 0.9);
    }

    .activity-dot {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .activity-dot.green { background: #dcfce7; color: var(--green); }
    .activity-dot.blue { background: #dbeafe; color: var(--blue); }
    .activity-dot.orange { background: #ffedd5; color: var(--fire); }
    .activity-dot.red { background: #fee2e2; color: var(--red-text); }

    .activity-text {
        flex: 1;
        min-width: 0;
    }

    .activity-text .primary {
        font-size: 13px;
        font-weight: 700;
        color: var(--t1);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .activity-text .secondary {
        font-size: 11px;
        color: var(--t3);
        margin-top: 2px;
    }

    .activity-time {
        font-size: 11px;
        color: var(--t3);
        white-space: nowrap;
        font-weight: 600;
    }

    .activity-empty {
        padding: 44px 24px;
        text-align: center;
        color: var(--t3);
        font-size: 13px;
    }

    .activity-empty i {
        font-size: 30px;
        opacity: 0.35;
        display: block;
        margin-bottom: 10px;
        color: var(--fire);
    }

    /* =============================================
       QUICK LINKS
    ============================================= */
    .quick-links {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
        padding: 0 24px 24px;
    }

    .q-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 14px;
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.95), rgba(241, 245, 249, 0.95));
        border: 1px solid rgba(148, 163, 184, 0.16);
        color: var(--t2);
        font-size: 12.5px;
        font-weight: 700;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .q-link i {
        font-size: 15px;
        color: var(--fire);
    }

    .q-link:hover {
        background: #fff;
        color: var(--t1);
        transform: translateY(-2px);
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
        border-color: rgba(251, 146, 60, 0.22);
    }

    /* =============================================
       TABLE / BRANCH SUMMARY
    ============================================= */
    .panel table {
        width: 100%;
        border-collapse: collapse;
    }

    .panel th,
    .panel td {
        padding-left: 0;
        padding-right: 0;
    }

    .panel tbody tr:hover {
        background: rgba(248, 250, 252, 0.8);
    }

    /* Alert box */
    .panel [style*="var(--red-bg)"] {
        border-radius: 16px !important;
        box-shadow: 0 10px 22px rgba(239, 68, 68, 0.08);
    }

    /* =============================================
       RESPONSIVE
    ============================================= */
    @@media (max-width: 1200px) {
        .d-cols-4 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .greeting-bar h1 {
            font-size: 28px;
        }
    }

    @@media (max-width: 1024px) {
        .d-cols-5-3 {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
    .d-cols-4,
    .d-cols-2 {
        grid-template-columns: 1fr;
    }

   

    .greeting-actions {
        width: 100%;
    }

    .g-btn {
        flex: 1;
        justify-content: center;
    }

    .quick-links {
        grid-template-columns: 1fr;
    }

    .panel-head,
    .panel-body {
        padding-left: 18px;
        padding-right: 18px;
    }

    .activity-item {
        padding-left: 18px;
        padding-right: 18px;
    }

}
        /* GREETING SECTION: white background, black text, orange name */
        .greeting-bar {
            background: #ffffff;
            border: 1px solid var(--border);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
            border-radius: 22px;
        }

            .greeting-bar::before {
                display: none;
            }

            .greeting-bar h1 {
                color: #111827;
            }

                .greeting-bar h1 span {
                    color: var(--fire);
                    text-shadow: none;
                }

        .greeting-meta {
            color: var(--t2);
        }

            .greeting-meta i {
                color: var(--fire);
            }

        /* BUTTONS: white background, black text */
        .g-btn.primary,
        .g-btn.outline {
            background: #ffffff;
            color: #111827;
            border: 1px solid var(--border);
            box-shadow: 0 6px 16px rgba(15, 23, 42, 0.06);
        }

            .g-btn.primary:hover,
            .g-btn.outline:hover {
                background: #f9fafb;
                color: #111827;
                border-color: var(--border-strong);
                transform: translateY(-2px);
            }

            .g-btn.primary i,
            .g-btn.outline i {
                color: var(--fire);
            }
</style>
}

<!-- ── GREETING ── -->
<div class="greeting-bar">
    <div>
        <h1>Welcome back, <span>@(User.Identity?.Name ?? "Admin")</span></h1>
        <div class="greeting-meta">
            <i class="bi bi-calendar3"></i>
            @DateTime.Now.ToString("dddd, MMMM d, yyyy")
        </div>
    </div>
    <div class="greeting-actions">
        <a asp-controller="Members" asp-action="Create" class="g-btn primary">
            <i class="bi bi-plus-lg"></i> New Member
        </a>
        <a asp-controller="Reception" asp-action="Index" class="g-btn outline">
            <i class="bi bi-display"></i> Reception
        </a>
    </div>
</div>

<!-- ── STATS ── -->
<div class="d-grid d-cols-4 d-section">
    <div class="stat">
        <div class="stat-ic orange"><i class="bi bi-people-fill"></i></div>
        <div class="stat-body">
            <div class="stat-val">@Model.ActiveMembers</div>
            <div class="stat-label">Active Members</div>
        </div>
        <div class="stat-accent orange"></div>
    </div>
    <div class="stat">
        <div class="stat-ic blue"><i class="bi bi-qr-code-scan"></i></div>
        <div class="stat-body">
            <div class="stat-val">@Model.AttendanceToday</div>
            <div class="stat-label">Today's Check-ins</div>
        </div>
        <div class="stat-accent blue"></div>
    </div>
    <div class="stat">
        <div class="stat-ic green"><i class="bi bi-person-check-fill"></i></div>
        <div class="stat-body">
            <div class="stat-val">@Model.CurrentlyInside</div>
            <div class="stat-label">Currently Inside</div>
        </div>
        <div class="stat-accent green"></div>
    </div>
    <div class="stat">
        <div class="stat-ic red"><i class="bi bi-exclamation-circle-fill"></i></div>
        <div class="stat-body">
            <div class="stat-val">@Model.ExpiringPackages</div>
            <div class="stat-label">Expiring (7 days)</div>
        </div>
        <div class="stat-accent red"></div>
    </div>
</div>

<!-- ── CHARTS ── -->
<div class="d-grid d-cols-2 d-section">
    <div class="panel">
        <div class="panel-head">
            <span class="panel-title">Attendance Trend</span>
            <a asp-controller="Attendance" asp-action="Index" class="panel-link">
                Details <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
        <div class="panel-body">
            <div class="chart-wrap">
                <div class="chart-empty">
                    <i class="bi bi-graph-up"></i>
                    <p>Attendance data will appear here once check-ins are recorded</p>
                </div>
            </div>
        </div>
    </div>
    <div class="panel">
        <div class="panel-head">
            <span class="panel-title">Branch Summary</span>
        </div>
        <div class="panel-body">
            @if (Model.BranchSummaries.Any())
            {
                <table style="width:100%; border-collapse:collapse; font-size:13px;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border);">
                            <th style="text-align:left; padding:6px 0; font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:var(--t3); font-weight:700;">Branch</th>
                            <th style="text-align:center; padding:6px 0; font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:var(--t3); font-weight:700;">Today</th>
                            <th style="text-align:center; padding:6px 0; font-size:10px; letter-spacing:.08em; text-transform:uppercase; color:var(--t3); font-weight:700;">Inside</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.BranchSummaries)
                        {
                            <tr style="border-bottom:1px solid var(--border);">
                                <td style="padding:10px 0;">
                                    <div style="font-weight:600; color:var(--t1);">@b.BranchName</div>
                                    <div style="font-size:11px; color:var(--t3);">@b.City</div>
                                </td>
                                <td style="text-align:center; padding:10px 0;">
                                    <span style="font-family:var(--font-display); font-size:18px; font-weight:800; color:var(--fire);">@b.AttendanceToday</span>
                                </td>
                                <td style="text-align:center; padding:10px 0;">
                                    <span style="font-family:var(--font-display); font-size:18px; font-weight:800; color:var(--green);">@b.CurrentlyInside</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="chart-empty" style="height:200px;">
                    <i class="bi bi-building"></i>
                    <p>No branches configured yet</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ── ACTIVITY + SHORTCUTS ── -->
<div class="d-grid d-cols-5-3 d-section">

    <!-- Recent Check-ins -->
    <div class="panel">
        <div class="panel-head">
            <span class="panel-title">Recent Check-ins</span>
            <a asp-controller="Attendance" asp-action="Index" class="panel-link">
                View All <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
        @if (Model.RecentAttendance.Any())
        {
            @foreach (var item in Model.RecentAttendance)
            {
                <div class="activity-item">
                    <div class="activity-dot @(item.OverrideApplied ? "orange" : "green")">
                        <i class="bi bi-box-arrow-in-right"></i>
                    </div>
                    <div class="activity-text">
                        <div class="primary">@item.MemberName</div>
                        <div class="secondary">
                            #@item.MembershipNumber · @item.BranchName
                            @if (item.OverrideApplied)
                            {
                                <span style="color:var(--fire);"> · Override</span>
                            }
                        </div>
                    </div>
                    <span class="activity-time">@item.CheckInAtUtc.ToLocalTime().ToString("HH:mm")</span>
                </div>
            }
        }
        else
        {
            <div class="activity-empty">
                <i class="bi bi-clock-history"></i>
                No check-ins today yet. They'll appear here as members arrive.
            </div>
        }
    </div>

    <!-- Quick Links -->
    <div class="panel">
        <div class="panel-head">
            <span class="panel-title">Quick Links</span>
        </div>
        <div class="quick-links">
            <a asp-controller="Members" asp-action="Create" class="q-link">
                <i class="bi bi-person-plus"></i> Add Member
            </a>
            <a asp-controller="Members" asp-action="Index" class="q-link">
                <i class="bi bi-people"></i> All Members
            </a>
            <a asp-controller="Attendance" asp-action="Index" class="q-link">
                <i class="bi bi-qr-code-scan"></i> Attendance
            </a>
            <a asp-controller="Reports" asp-action="Index" class="q-link">
                <i class="bi bi-bar-chart-line"></i> Reports
            </a>
            <a asp-controller="Branches" asp-action="Index" class="q-link">
                <i class="bi bi-building"></i> Branches
            </a>
            <a asp-controller="PackageCatalog" asp-action="Index" class="q-link">
                <i class="bi bi-box-seam"></i> Catalog
            </a>
        </div>

        @if (Model.LowSessionMembers > 0)
        {
            <div style="margin: 0 24px 24px; padding:12px 14px; background:var(--red-bg); border:1px solid var(--red-border); border-radius:var(--r-sm); display:flex; align-items:center; gap:10px;">
                <i class="bi bi-exclamation-triangle-fill" style="color:var(--red-text); font-size:16px; flex-shrink:0;"></i>
                <div>
                    <div style="font-size:12.5px; font-weight:700; color:var(--red-text);">@Model.LowSessionMembers member@(Model.LowSessionMembers != 1 ? "s" : "") low on sessions</div>
                    <div style="font-size:11px; color:var(--t3); margin-top:1px;">≤ 2 sessions remaining</div>
                </div>
            </div>
        }
    </div>

</div>
