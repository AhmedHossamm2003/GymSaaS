@model GymSaaS.Models.ReportsViewModel
@using GymSaaS.Models
@{
    ViewData["Title"] = "Reports";
    ViewData["Subtitle"] = "Performance dashboard";
    var branches = ViewData["Branches"] as List<BranchDropdownItem> ?? new();

    var presets = new[]
    {
        ("this_month",   "This Month"),
        ("last_month",   "Last Month"),
        ("last_3_months","Last 3 Months"),
        ("last_6_months","Last 6 Months"),
        ("this_year",    "This Year"),
        ("last_year",    "Last Year"),
    };

    string ChangeBadge(decimal pct, bool inverted = false)
    {
        if (pct == 0) return "<span style='color:#94a3b8;font-size:11px;font-weight:600;'>= 0%</span>";
        bool isPositive = inverted ? pct < 0 : pct > 0;
        var color = isPositive ? "#16a34a" : "#dc2626";
        var arrow = pct > 0 ? "▲" : "▼";
        var sign  = pct > 0 ? "+" : "";
        return $"<span style='color:{color};font-size:11px;font-weight:700;'>{arrow} {sign}{pct}%</span>";
    }
}

@section Styles {
<style>
    .rpt-shell { max-width: 1200px; }

    /* Filter bar */
    .rpt-filterbar {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        padding: 14px 18px;
        margin-bottom: 18px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }
    .preset-pill {
        padding: 6px 14px;
        border-radius: 999px;
        border: 1px solid rgba(15,23,42,0.08);
        background: #fff;
        font-size: 12px;
        font-weight: 700;
        color: var(--t2);
        cursor: pointer;
        text-decoration: none;
        transition: all .18s ease;
    }
    .preset-pill:hover { border-color: rgba(249,115,22,0.40); color: var(--fire); }
    .preset-pill.active {
        background: linear-gradient(135deg, var(--fire-soft), rgba(249,115,22,0.10));
        border-color: var(--fire-border);
        color: var(--fire-text);
        box-shadow: 0 1px 2px rgba(249,115,22,0.12);
    }

    /* Stat tiles */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 18px;
    }
    @@media (max-width: 900px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 540px) { .stat-grid { grid-template-columns: 1fr; } }

    .stat-tile {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        padding: 18px 20px;
        position: relative;
        overflow: hidden;
        transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    }
    .stat-tile::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.9), transparent);
    }
    .stat-tile:hover {
        box-shadow: 0 4px 8px rgba(15,23,42,0.05), 0 12px 28px rgba(15,23,42,0.08);
        border-color: rgba(15,23,42,0.10);
        transform: translateY(-2px);
    }
    .stat-tile.income { border-top: 3px solid var(--fire); }
    .stat-tile.expense { border-top: 3px solid #dc2626; }
    .stat-tile.net { border-top: 3px solid #16a34a; }
    .stat-tile.margin { border-top: 3px solid #3b82f6; }

    .st-lbl {
        font-size: 10.5px; font-weight: 700;
        letter-spacing: .12em; text-transform: uppercase;
        color: var(--t3);
        margin-bottom: 6px;
    }
    .st-val {
        font-family: var(--font-display);
        font-size: 28px; font-weight: 800;
        color: var(--t1); line-height: 1;
        letter-spacing: -.01em;
    }
    .st-val.fire { color: var(--fire); }
    .st-val.red { color: #dc2626; }
    .st-val.green { color: #16a34a; }
    .st-sub {
        font-size: 11.5px; color: var(--t3);
        margin-top: 6px;
    }

    /* Sections */
    .rpt-section {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        overflow: hidden;
        margin-bottom: 18px;
    }
    .rpt-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1px solid rgba(15,23,42,0.05);
        background: linear-gradient(to bottom, #fafafa, #f5f5f7);
    }
    .rpt-title {
        font-family: var(--font-display);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--t1);
    }
    .rpt-body { padding: 18px 20px; }

    /* Bar chart (CSS-only) */
    .chart-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 14px;
        align-items: end;
        padding: 14px 0 4px;
    }
    .chart-col {
        display: flex; flex-direction: column; align-items: center; gap: 6px;
    }
    .chart-bars {
        display: flex; gap: 4px; align-items: flex-end;
        height: 160px;
    }
    .chart-bar {
        width: 14px;
        background: var(--fire);
        border-radius: 4px 4px 0 0;
        position: relative;
        min-height: 2px;
        transition: opacity .2s;
    }
    .chart-bar:hover { opacity: .8; }
    .chart-bar.expense { background: #dc2626; }
    .chart-label {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--t3);
        letter-spacing: .05em;
        text-transform: uppercase;
        text-align: center;
    }
    .chart-vals {
        font-size: 10px;
        color: var(--t3);
        text-align: center;
        line-height: 1.4;
    }
    .chart-vals .income-val { color: var(--fire); font-weight: 700; }
    .chart-vals .expense-val { color: #dc2626; font-weight: 700; }
    .chart-legend {
        display: flex; gap: 16px; justify-content: center;
        padding: 10px 0 0;
        border-top: 1px solid rgba(15,23,42,0.06);
        margin-top: 8px;
        font-size: 11.5px; font-weight: 600;
        color: var(--t2);
    }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: middle; }

    /* Two-column layout for sections */
    .rpt-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 18px;
    }
    @@media (max-width: 900px) { .rpt-two-col { grid-template-columns: 1fr; } }

    /* Category bars */
    .cat-row {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid rgba(15,23,42,0.04);
    }
    .cat-row:last-child { border-bottom: none; }
    .cat-name { flex: 0 0 140px; font-size: 12.5px; font-weight: 600; color: var(--t1); }
    .cat-bar-bg {
        flex: 1;
        height: 8px;
        background: rgba(15,23,42,0.06);
        border-radius: 999px;
        overflow: hidden;
    }
    .cat-bar-fill {
        height: 100%;
        border-radius: 999px;
        transition: width .4s;
    }
    .cat-bar-fill.income { background: linear-gradient(90deg, var(--fire), #fdba74); }
    .cat-bar-fill.expense { background: linear-gradient(90deg, #dc2626, #fb7185); }
    .cat-val {
        font-size: 13px; font-weight: 700;
        color: var(--t1);
        min-width: 80px;
        text-align: right;
        font-family: var(--font-display);
    }
    .cat-pct { font-size: 10.5px; color: var(--t3); margin-left: 4px; font-weight: 600; }

    /* Table */
    .rpt-table { width: 100%; border-collapse: collapse; }
    .rpt-table thead th {
        background: linear-gradient(to bottom, #fafafa, #f5f5f7);
        padding: 11px 16px;
        text-align: left;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--t3);
        border-bottom: 1px solid rgba(15,23,42,0.08);
    }
    .rpt-table tbody tr { border-bottom: 1px solid rgba(15,23,42,0.04); }
    .rpt-table tbody tr:last-child { border-bottom: none; }
    .rpt-table tbody tr:hover { background: #fafafa; }
    .rpt-table tbody td { padding: 11px 16px; font-size: 12.5px; vertical-align: middle; }
    .rpt-table .num { text-align: right; font-weight: 700; font-family: var(--font-display); font-size: 13.5px; }
    .rpt-table .num.fire { color: var(--fire); }
    .rpt-table .num.red { color: #dc2626; }
    .rpt-table .num.green { color: #16a34a; }
    .rpt-table .num.neg { color: #dc2626; }

    .empty-mini {
        text-align: center; padding: 28px 14px; color: var(--t3);
        font-size: 12.5px;
    }
</style>
}

<div class="rpt-shell">

    <!-- Header + Export buttons -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:18px;">
        <div>
            <h1 style="font-family:var(--font-display);font-size:22px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--t1);margin:0;">
                Reports & Analytics
            </h1>
            <p style="font-size:13px;color:var(--t3);margin:3px 0 0;">
                <strong style="color:var(--t1);font-weight:700;">@Model.RangeLabel</strong>
                @if (!string.IsNullOrEmpty(Model.BranchFilterName))
                {
                    <span> · @Model.BranchFilterName</span>
                }
                <span style="color:var(--t4);"> · vs @Model.ComparisonStart.ToString("MMM d") – @Model.ComparisonEnd.ToString("MMM d")</span>
            </p>
        </div>
        <div style="display:flex;gap:8px;">
            <a asp-action="ExportExcel"
               asp-route-preset="@Model.RangePreset"
               asp-route-fromDate="@Model.RangeStart"
               asp-route-toDate="@Model.RangeEnd"
               asp-route-branchId="@Model.BranchFilterId"
               class="btn btn-secondary">
                <i class="bi bi-file-earmark-spreadsheet" style="color:#16a34a;"></i> Excel
            </a>
            <a asp-action="ExportPdf"
               asp-route-preset="@Model.RangePreset"
               asp-route-fromDate="@Model.RangeStart"
               asp-route-toDate="@Model.RangeEnd"
               asp-route-branchId="@Model.BranchFilterId"
               class="btn btn-primary">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </a>
        </div>
    </div>

    <!-- Filter Bar -->
    <form method="get" class="rpt-filterbar">
        @foreach (var (code, name) in presets)
        {
            <a href="@Url.Action("Index", new { preset = code, branchId = Model.BranchFilterId })"
               class="preset-pill @(Model.RangePreset == code ? "active" : "")">@name</a>
        }

        <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
            <select name="branchId" class="form-control" style="max-width:170px;font-size:12.5px;" onchange="this.form.submit()">
                <option value="">All Branches</option>
                @foreach (var b in branches)
                {
                    if (Model.BranchFilterId == b.BranchId)
                    {
                        <option value="@b.BranchId" selected>@b.BranchName</option>
                    }
                    else
                    {
                        <option value="@b.BranchId">@b.BranchName</option>
                    }
                }
            </select>
            <input type="hidden" name="preset" value="@Model.RangePreset" />
        </div>
    </form>

    <!-- Financial Summary Tiles -->
    <div class="stat-grid">
        <div class="stat-tile income">
            <div class="st-lbl">Total Income</div>
            <div class="st-val fire">@Model.TotalIncome.ToString("N2")</div>
            <div class="st-sub">@Html.Raw(ChangeBadge(Model.IncomeChangePct)) vs prev</div>
        </div>
        <div class="stat-tile expense">
            <div class="st-lbl">Total Expenses</div>
            <div class="st-val red">@Model.TotalExpenses.ToString("N2")</div>
            <div class="st-sub">@Html.Raw(ChangeBadge(Model.ExpenseChangePct, inverted: true)) vs prev</div>
        </div>
        <div class="stat-tile net">
            <div class="st-lbl">Net Profit</div>
            <div class="st-val @(Model.NetProfit < 0 ? "red" : "green")">@Model.NetProfit.ToString("N2")</div>
            <div class="st-sub">@Html.Raw(ChangeBadge(Model.NetChangePct)) vs prev</div>
        </div>
        <div class="stat-tile margin">
            <div class="st-lbl">Profit Margin</div>
            <div class="st-val" style="color:#3b82f6;">@Model.ProfitMarginPct%</div>
            <div class="st-sub" style="color:var(--t3);">of total income</div>
        </div>
    </div>

    <!-- Member Analytics Tiles -->
    <div class="stat-grid">
        <div class="stat-tile">
            <div class="st-lbl">Total Members</div>
            <div class="st-val">@Model.TotalMembers.ToString("N0")</div>
            <div class="st-sub" style="color:var(--t3);">all-time, not deleted</div>
        </div>
        <div class="stat-tile">
            <div class="st-lbl">Active Now</div>
            <div class="st-val green">@Model.ActiveMembers.ToString("N0")</div>
            <div class="st-sub" style="color:var(--t3);">currently subscribed</div>
        </div>
        <div class="stat-tile">
            <div class="st-lbl">New This Period</div>
            <div class="st-val fire">@Model.NewMembersInPeriod.ToString("N0")</div>
            <div class="st-sub">@Html.Raw(ChangeBadge(Model.NewMembersChangePct)) vs prev (@Model.PrevPeriodNewMembers)</div>
        </div>
        <div class="stat-tile">
            <div class="st-lbl">Check-Ins</div>
            <div class="st-val">@Model.TotalCheckInsInPeriod.ToString("N0")</div>
            <div class="st-sub">@Html.Raw(ChangeBadge(Model.CheckInsChangePct)) vs prev · avg @Model.AvgDailyCheckIns/day</div>
        </div>
    </div>

    <!-- 6-Month Trend Chart -->
    @{
        var maxVal = Model.MonthlyTrend.Any() ? (decimal)Math.Max(1, (double)Math.Max(Model.MonthlyTrend.Max(m => m.Income), Model.MonthlyTrend.Max(m => m.Expenses))) : 1m;
    }
    @if (Model.MonthlyTrend.Any())
    {
        <div class="rpt-section">
            <div class="rpt-head">
                <span class="rpt-title">6-Month Income vs Expenses</span>
                <span style="font-size:11px;color:var(--t3);font-weight:600;">trend (last 6 months ending @Model.RangeEnd.ToString("MMM yyyy"))</span>
            </div>
            <div class="rpt-body">
                <div class="chart-grid">
                    @foreach (var m in Model.MonthlyTrend)
                    {
                        int incomeH = Math.Max(2, (int)(((double)m.Income / (double)maxVal) * 160));
                        int expenseH = Math.Max(2, (int)(((double)m.Expenses / (double)maxVal) * 160));
                        <div class="chart-col">
                            <div class="chart-bars">
                                <div class="chart-bar" style="height:@(incomeH)px;" title="Income: @m.Income.ToString("N2")"></div>
                                <div class="chart-bar expense" style="height:@(expenseH)px;" title="Expenses: @m.Expenses.ToString("N2")"></div>
                            </div>
                            <div class="chart-label">@m.MonthLabel.Substring(0, 3)</div>
                            <div class="chart-vals">
                                <div class="income-val">@m.Income.ToString("N0")</div>
                                <div class="expense-val">@m.Expenses.ToString("N0")</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="chart-legend">
                    <span><span class="legend-dot" style="background:var(--fire);"></span> Income</span>
                    <span><span class="legend-dot" style="background:#dc2626;"></span> Expenses</span>
                </div>
            </div>
        </div>
    }

    <!-- Income & Expense breakdowns -->
    <div class="rpt-two-col">
        <div class="rpt-section">
            <div class="rpt-head"><span class="rpt-title">Income by Category</span></div>
            <div class="rpt-body">
                @if (!Model.IncomeByCategory.Any())
                {
                    <div class="empty-mini">No income recorded in this period.</div>
                }
                else
                {
                    @foreach (var c in Model.IncomeByCategory)
                    {
                        <div class="cat-row">
                            <div class="cat-name">@c.CategoryName</div>
                            <div class="cat-bar-bg"><div class="cat-bar-fill income" style="width:@c.Percent%;"></div></div>
                            <div class="cat-val">@c.Amount.ToString("N2") <span class="cat-pct">@c.Percent%</span></div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="rpt-section">
            <div class="rpt-head"><span class="rpt-title">Expenses by Category</span></div>
            <div class="rpt-body">
                @if (!Model.ExpenseByCategory.Any())
                {
                    <div class="empty-mini">No expenses recorded in this period.</div>
                }
                else
                {
                    @foreach (var c in Model.ExpenseByCategory)
                    {
                        <div class="cat-row">
                            <div class="cat-name">@c.CategoryName</div>
                            <div class="cat-bar-bg"><div class="cat-bar-fill expense" style="width:@c.Percent%;"></div></div>
                            <div class="cat-val">@c.Amount.ToString("N2") <span class="cat-pct">@c.Percent%</span></div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Top Packages -->
    @if (Model.TopSellingPackages.Any())
    {
        <div class="rpt-section">
            <div class="rpt-head">
                <span class="rpt-title">Top Selling Packages</span>
                <span style="font-size:11px;color:var(--t3);font-weight:600;">in this period</span>
            </div>
            <table class="rpt-table">
                <thead>
                    <tr>
                        <th>Package</th>
                        <th style="text-align:right;">Sales</th>
                        <th style="text-align:right;">Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.TopSellingPackages)
                    {
                        <tr>
                            <td style="font-weight:600;color:var(--t1);">@p.PackageName</td>
                            <td class="num" style="font-size:13.5px;">@p.AssignmentCount</td>
                            <td class="num fire">@p.TotalRevenue.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Branch Performance -->
    @if (Model.BranchPerformance.Any())
    {
        <div class="rpt-section">
            <div class="rpt-head"><span class="rpt-title">Branch Performance</span></div>
            <table class="rpt-table">
                <thead>
                    <tr>
                        <th>Branch</th>
                        <th style="text-align:right;">Income</th>
                        <th style="text-align:right;">Expenses</th>
                        <th style="text-align:right;">Net</th>
                        <th style="text-align:right;">New</th>
                        <th style="text-align:right;">Visits</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.BranchPerformance)
                    {
                        <tr>
                            <td style="font-weight:700;color:var(--t1);">
                                <i class="bi bi-building" style="font-size:11px;color:var(--t3);margin-right:5px;"></i>
                                @b.BranchName
                            </td>
                            <td class="num fire">@b.Income.ToString("N2")</td>
                            <td class="num red">@b.Expenses.ToString("N2")</td>
                            <td class="num @(b.Net < 0 ? "red" : "green")">@b.Net.ToString("N2")</td>
                            <td class="num">@b.NewMembers</td>
                            <td class="num">@b.CheckIns</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>
