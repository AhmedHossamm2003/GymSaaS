@model List<GymSaaS.Models.WorkoutTemplateListItem>

@{
    var search     = ViewData["Search"] as string;
    var difficulty = ViewData["Difficulty"] as byte?;
    var total      = (int)(ViewData["TotalCount"] ?? 0);
    var active     = (int)(ViewData["ActiveCount"] ?? 0);
}

<!-- Page header -->
<div class="page-header">
    <div>
        <div class="page-title">Workout Templates</div>
        <div class="page-subtitle">Build and manage reusable exercise routines</div>
    </div>
    <a asp-controller="WorkoutTemplates" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Template
    </a>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:24px">
    <div class="stat-card highlight">
        <div class="stat-icon"><i class="bi bi-journal-text"></i></div>
        <div>
            <div class="stat-value">@total</div>
            <div class="stat-label">Total Templates</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        <div>
            <div class="stat-value">@active</div>
            <div class="stat-label">Active</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
        <div>
            <div class="stat-value">@(total - active)</div>
            <div class="stat-label">Inactive</div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom:20px;padding:16px 20px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <div style="flex:1;min-width:200px;display:flex;align-items:center;gap:8px;background:var(--bg-raised);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0 12px">
            <i class="bi bi-search" style="color:var(--text-faint);font-size:13px"></i>
            <input type="text" name="search" value="@search" placeholder="Search templates…"
                   style="border:none;background:transparent;outline:none;padding:8px 0;font-size:13px;width:100%"/>
        </div>

        <select name="difficulty" style="min-width:140px">
            <option value="">All Levels</option>
            <option value="1" selected="@(difficulty == 1)">Beginner</option>
            <option value="2" selected="@(difficulty == 2)">Intermediate</option>
            <option value="3" selected="@(difficulty == 3)">Advanced</option>
        </select>

        <button type="submit" class="btn btn-secondary"><i class="bi bi-funnel"></i> Filter</button>
        @if (!string.IsNullOrWhiteSpace(search) || difficulty.HasValue)
        {
            <a asp-controller="WorkoutTemplates" asp-action="Index" class="btn btn-ghost">Clear</a>
        }
    </form>
</div>

<!-- Template cards -->
@if (!Model.Any())
{
    <div class="card" style="text-align:center;padding:60px 24px">
        <i class="bi bi-journal-text" style="font-size:40px;color:var(--text-faint)"></i>
        <div style="margin-top:12px;color:var(--text-muted);font-size:14px">No workout templates found.</div>
        <a asp-controller="WorkoutTemplates" asp-action="Create" class="btn btn-primary" style="margin-top:16px;display:inline-flex">
            <i class="bi bi-plus-lg"></i> Create First Template
        </a>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
        @foreach (var t in Model)
        {
            <div class="card" style="padding:20px;display:flex;flex-direction:column;gap:14px">

                <!-- Header -->
                <div style="display:flex;align-items:flex-start;gap:10px">
                    <div style="width:44px;height:44px;border-radius:8px;background:var(--bg-raised);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--border)">
                        <i class="bi bi-journal-text" style="font-size:20px;color:var(--orange)"></i>
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-weight:700;font-size:14px;color:var(--black);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@t.TemplateName</div>
                        @if (!string.IsNullOrEmpty(t.Description))
                        {
                            <div style="font-size:12px;color:var(--text-secondary);margin-top:2px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">@t.Description</div>
                        }
                    </div>
                    <span class="badge @(t.IsActive ? "badge-active" : "badge-inactive")" style="flex-shrink:0">
                        @(t.IsActive ? "Active" : "Inactive")
                    </span>
                </div>

                <!-- Chips -->
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <span style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;background:@(t.DifficultyColor)1a;color:@t.DifficultyColor;border:1px solid @(t.DifficultyColor)40">
                        @t.DifficultyLabel
                    </span>
                    <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:var(--bg-raised);color:var(--text-secondary);border:1px solid var(--border)">
                        <i class="bi bi-activity" style="font-size:10px"></i> @t.ExerciseCount @(t.ExerciseCount == 1 ? "exercise" : "exercises")
                    </span>
                    @if (t.EstimatedMinutes.HasValue)
                    {
                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:var(--bg-raised);color:var(--text-secondary);border:1px solid var(--border)">
                            <i class="bi bi-clock" style="font-size:10px"></i> ~@t.EstimatedMinutes min
                        </span>
                    }
                </div>

                <!-- Actions -->
                <div style="display:flex;gap:8px;border-top:1px solid var(--border);padding-top:12px;margin-top:auto">
                    <a asp-controller="WorkoutTemplates" asp-action="Edit" asp-route-id="@t.WorkoutTemplateId"
                       class="btn btn-secondary" style="flex:1;justify-content:center;font-size:12px">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form asp-controller="WorkoutTemplates" asp-action="Delete" asp-route-id="@t.WorkoutTemplateId"
                          method="post" onsubmit="return confirm('Remove \'@t.TemplateName\'?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" style="font-size:12px">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>

            </div>
        }
    </div>
}
