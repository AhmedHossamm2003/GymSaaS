@model GymSaaS.Models.ManualIncomeFormViewModel
@using GymSaaS.Models
@{
    ViewData["Title"] = "Income";
    ViewData["Subtitle"] = Model.IsEdit ? "Edit Entry" : "Add Income Entry";
}

@section Styles {
<style>
    .form-shell { max-width: 640px; }
    .form-card {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        overflow: hidden;
        position: relative;
    }
    .form-card::before {
        content: '';
        position: absolute;
        top: 0; left: 24px; right: 24px;
        height: 2px;
        background: linear-gradient(90deg, #16a34a, #4ade80, transparent);
        border-radius: 0 0 2px 2px;
    }
    .form-card-head {
        padding: 18px 24px;
        border-bottom: 1px solid rgba(15,23,42,0.05);
        background: linear-gradient(to bottom, #fafafa, #f5f5f7);
    }
    .form-card-body { padding: 24px; }
    .form-grid-2 {
        display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    }
    @@media (max-width: 600px) { .form-grid-2 { grid-template-columns: 1fr; } }
    .form-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .form-label-up {
        font-size: 11px; font-weight: 700;
        letter-spacing: .08em; text-transform: uppercase;
        color: var(--t3);
    }
    .form-actions {
        display: flex; gap: 10px; justify-content: flex-end;
        padding: 18px 24px; border-top: 1px solid rgba(15,23,42,0.05);
        background: #fafafa;
    }
    .field-error { color: var(--red); font-size: 11.5px; font-weight: 600; }
</style>
}

<div class="form-shell">
    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--t2);margin-bottom:18px;">
        <i class="bi bi-arrow-left"></i> Back to Income
    </a>

    <h1 style="font-family:var(--font-display);font-size:22px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--t1);margin-bottom:16px;">
        @(Model.IsEdit ? "Edit Income" : "Add Income")
    </h1>

    <form asp-action="@(Model.IsEdit ? "Edit" : "Create")"
          asp-route-id="@Model.IncomeEntryId"
          method="post" class="form-card">
        @Html.AntiForgeryToken()

        <div class="form-card-head">
            <strong style="font-size:13px;letter-spacing:.04em;text-transform:uppercase;color:var(--t1);">Income Entry</strong>
        </div>

        <div class="form-card-body">

            <div class="form-grid-2">
                <div class="form-field">
                    <label class="form-label-up">Category *</label>
                    <select name="CategoryCode" class="form-control" required>
                        <option value="">Select category…</option>
                        @foreach (var (code, name) in IncomeCategories.All)
                        {
                            if (code == Model.CategoryCode)
                            {
                                <option value="@code" selected>@name</option>
                            }
                            else
                            {
                                <option value="@code">@name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryCode" class="field-error"></span>
                </div>

                <div class="form-field">
                    <label class="form-label-up">Branch (optional)</label>
                    <select name="BranchId" class="form-control">
                        <option value="">All Branches</option>
                        @foreach (var b in Model.Branches)
                        {
                            if (Model.BranchId == b.BranchId)
                            {
                                <option value="@b.BranchId" selected>@b.BranchName</option>
                            }
                            else
                            {
                                <option value="@b.BranchId">@b.BranchName</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="form-field">
                <label class="form-label-up">Description *</label>
                <input type="text" name="Description" value="@Model.Description"
                       class="form-control" placeholder="e.g. Day pass — 3 people"
                       maxlength="200" required />
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-grid-2">
                <div class="form-field">
                    <label class="form-label-up">Amount *</label>
                    <input type="number" name="Amount" value="@Model.Amount" class="form-control"
                           min="0.01" step="0.01" placeholder="0.00" required />
                    <span asp-validation-for="Amount" class="field-error"></span>
                </div>

                <div class="form-field">
                    <label class="form-label-up">Date *</label>
                    <input type="date" name="IncomeDate" value="@Model.IncomeDate.ToString("yyyy-MM-dd")"
                           class="form-control" required />
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-field">
                    <label class="form-label-up">Payment Method</label>
                    <select name="PaymentMethod" class="form-control">
                        <option value="">—</option>
                        @foreach (var (code, name) in PaymentMethods.All)
                        {
                            if (code == Model.PaymentMethod)
                            {
                                <option value="@code" selected>@name</option>
                            }
                            else
                            {
                                <option value="@code">@name</option>
                            }
                        }
                    </select>
                </div>
                <div></div>
            </div>

            <div class="form-field">
                <label class="form-label-up">Notes</label>
                <textarea name="Notes" rows="3" class="form-control"
                          placeholder="Optional notes" maxlength="1000">@Model.Notes</textarea>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn btn-ghost" style="border:1px solid var(--border);">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> @(Model.IsEdit ? "Save" : "Add Entry")
            </button>
        </div>
    </form>
</div>
