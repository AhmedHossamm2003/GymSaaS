@model List<GymSaaS.Models.ExpenseListItem>
@using GymSaaS.Models
@{
    ViewData["Title"] = "Expenses";
    ViewData["Subtitle"] = "Track operating costs";

    var category   = ViewData["Category"] as string ?? "";
    var branchId   = ViewData["BranchId"] as Guid?;
    var fromDate   = (DateOnly)ViewData["FromDate"]!;
    var toDate     = (DateOnly)ViewData["ToDate"]!;
    var page       = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalCount = (int)(ViewData["TotalCount"] ?? 0);
    var totalAmount= (decimal)(ViewData["TotalAmount"] ?? 0m);
    var branches   = ViewData["Branches"] as List<BranchDropdownItem> ?? new();
}

@section Styles {
<style>
    .fin-shell { max-width: 1100px; }
    .fin-toolbar {
        display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
        margin-bottom: 18px;
    }
    .total-badge {
        display: inline-flex; align-items: center; gap: 8px;
        background: linear-gradient(135deg, #fff4ed, rgba(249,115,22,0.10));
        border: 1px solid var(--fire-border);
        border-radius: 12px;
        padding: 10px 16px;
        color: var(--fire-text);
        font-weight: 800;
        margin-left: auto;
    }
    .total-badge .lbl {
        font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase;
        font-weight: 700; color: var(--fire); opacity: .9;
    }
    .total-badge .val {
        font-family: var(--font-display);
        font-size: 22px; font-weight: 800;
        color: var(--fire-text);
        letter-spacing: -.01em;
    }
    .fin-table-card {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        overflow: hidden;
        transition: box-shadow 0.25s ease;
    }
    .fin-table-card:hover {
        box-shadow: 0 2px 4px rgba(15,23,42,0.05), 0 8px 22px rgba(15,23,42,0.06);
    }
    .fin-table { width: 100%; border-collapse: collapse; }
    .fin-table thead th {
        background: linear-gradient(to bottom, #fafafa, #f5f5f7);
        padding: 12px 18px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--t3);
        border-bottom: 1px solid rgba(15,23,42,0.08);
    }
    .fin-table tbody tr {
        border-bottom: 1px solid rgba(15,23,42,0.04);
        transition: background .15s ease, box-shadow .15s ease;
    }
    .fin-table tbody tr:hover {
        background: #fafafa;
        box-shadow: inset 3px 0 0 var(--fire);
    }
    .fin-table tbody td {
        padding: 13px 18px;
        font-size: 13px;
        vertical-align: middle;
    }
    .amount-cell {
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 800;
        color: var(--fire);
        white-space: nowrap;
    }
    .cat-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 10px; border-radius: 999px;
        font-size: 11.5px; font-weight: 700;
        background: rgba(15,23,42,0.05);
        color: var(--t2);
        border: 1px solid rgba(15,23,42,0.06);
    }
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--t3);
    }
    .empty-state i { font-size: 42px; opacity: .35; display: block; margin-bottom: 14px; color: var(--fire); }
    .empty-state .lbl { font-weight: 700; color: var(--t2); margin-bottom: 6px; font-size: 14px; }
</style>
}

<div class="fin-shell">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
        <div>
            <h1 style="font-family:var(--font-display);font-size:22px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--t1);margin:0;">
                Expenses
            </h1>
            <p style="font-size:13px;color:var(--t3);margin:3px 0 0;">Track operating costs across branches</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Expense
        </a>
    </div>

    <!-- Filters / Date Range / Total -->
    <form method="get" class="fin-toolbar">
        <select name="category" class="form-control" style="max-width:200px;" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var (code, name) in ExpenseCategories.All)
            {
                if (code == category)
                {
                    <option value="@code" selected>@name</option>
                }
                else
                {
                    <option value="@code">@name</option>
                }
            }
        </select>

        <select name="branchId" class="form-control" style="max-width:180px;" onchange="this.form.submit()">
            <option value="">All Branches</option>
            @foreach (var b in branches)
            {
                if (branchId == b.BranchId)
                {
                    <option value="@b.BranchId" selected>@b.BranchName</option>
                }
                else
                {
                    <option value="@b.BranchId">@b.BranchName</option>
                }
            }
        </select>

        <input type="date" name="fromDate" value="@fromDate.ToString("yyyy-MM-dd")" class="form-control" style="max-width:160px;" />
        <span style="color:var(--t3);font-weight:600;">→</span>
        <input type="date" name="toDate" value="@toDate.ToString("yyyy-MM-dd")" class="form-control" style="max-width:160px;" />

        <button type="submit" class="btn btn-secondary">
            <i class="bi bi-funnel"></i> Apply
        </button>

        <div class="total-badge">
            <div>
                <div class="lbl">Total</div>
                <div class="val">@totalAmount.ToString("N2")</div>
            </div>
        </div>
    </form>

    <!-- Table -->
    <div class="fin-table-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-receipt"></i>
                <div class="lbl">No expenses found</div>
                <div style="font-size:13px;">Try adjusting filters, or <a asp-action="Create" style="color:var(--fire);font-weight:700;">add your first expense</a>.</div>
            </div>
        }
        else
        {
            <table class="fin-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Category</th>
                        <th>Vendor</th>
                        <th>Branch</th>
                        <th>Method</th>
                        <th style="text-align:right;">Amount</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td style="white-space:nowrap;color:var(--t2);">
                                <strong style="color:var(--t1);font-weight:700;">@e.ExpenseDate.ToString("MMM d")</strong>
                                <div style="font-size:11px;color:var(--t3);">@e.ExpenseDate.ToString("yyyy")</div>
                            </td>
                            <td><span class="cat-pill">@e.CategoryName</span></td>
                            <td style="color:var(--t1);font-weight:600;">@(e.VendorName ?? "—")</td>
                            <td style="color:var(--t2);font-size:12.5px;">@(e.BranchName ?? "All Branches")</td>
                            <td style="color:var(--t2);font-size:12px;">@(string.IsNullOrEmpty(e.PaymentMethod) ? "—" : e.PaymentMethod)</td>
                            <td style="text-align:right;" class="amount-cell">@e.Amount.ToString("N2")</td>
                            <td style="text-align:right;white-space:nowrap;">
                                <a asp-action="Edit" asp-route-id="@e.ExpenseId" class="btn btn-ghost" style="padding:4px 8px;border:1px solid var(--border);">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@e.ExpenseId" method="post" style="display:inline;"
                                      onsubmit="return confirm('Delete this expense?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost" style="padding:4px 8px;color:var(--red);border:1px solid var(--border);">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div style="padding:14px 18px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                    <span style="font-size:12px;color:var(--t3);">@totalCount expense@(totalCount != 1 ? "s" : "")</span>
                    <div style="display:flex;gap:6px;">
                        @if (page > 1)
                        {
                            <a href="@Url.Action("Index", new { category, branchId, fromDate, toDate, page = page - 1 })"
                               class="btn btn-ghost" style="padding:5px 12px;border:1px solid var(--border);font-size:12px;">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }
                        <span style="padding:5px 12px;font-size:12px;font-weight:600;color:var(--t2);">@(page) / @totalPages</span>
                        @if (page < totalPages)
                        {
                            <a href="@Url.Action("Index", new { category, branchId, fromDate, toDate, page = page + 1 })"
                               class="btn btn-ghost" style="padding:5px 12px;border:1px solid var(--border);font-size:12px;">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
