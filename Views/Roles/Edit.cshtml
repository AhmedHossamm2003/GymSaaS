@model GymSaaS.Models.EditRoleViewModel

@{
    ViewData["Title"] = "Edit Role";
}

<div class="mb-4">
    <h2 class="mb-1">Edit Role</h2>
    <p class="text-muted mb-0">Update role details and accessible view folders.</p>
</div>

@if (Model.IsSystem)
{
    <div class="alert alert-info">
        This is a system role and cannot be edited.
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input asp-for="RoleId" type="hidden" />
            <input asp-for="IsSystem" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="RoleName" class="form-label"></label>
                    @if (Model.IsSystem)
                    {
                        <input asp-for="RoleName" class="form-control" readonly="readonly" />
                    }
                    else
                    {
                        <input asp-for="RoleName" class="form-control" />
                    }
                    <span asp-validation-for="RoleName" class="text-danger"></span>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check form-switch">
                        @if (Model.IsSystem)
                        {
                            <input asp-for="IsActive" class="form-check-input" disabled="disabled" />
                        }
                        else
                        {
                            <input asp-for="IsActive" class="form-check-input" />
                        }
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="RoleDescription" class="form-label"></label>
                    @if (Model.IsSystem)
                    {
                        <textarea asp-for="RoleDescription" class="form-control" rows="3" readonly="readonly"></textarea>
                    }
                    else
                    {
                        <textarea asp-for="RoleDescription" class="form-control" rows="3"></textarea>
                    }
                    <span asp-validation-for="RoleDescription" class="text-danger"></span>
                </div>
            </div>

            <hr class="my-4" />

            <h5 class="mb-3">Allowed View Folders</h5>
            <p class="text-muted">
                Selecting a folder gives this role access to all pages inside that folder.
            </p>

            @if (!Model.Permissions.Any())
            {
                <div class="alert alert-warning">
                    No eligible view folders were found.
                </div>
            }
            else
            {
                <div class="row">
                    @for (int i = 0; i < Model.Permissions.Count; i++)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="form-check border rounded p-3">
                                <input type="hidden" asp-for="Permissions[@i].ViewPermissionId" />
                                <input type="hidden" asp-for="Permissions[@i].DisplayName" />
                                <input type="hidden" asp-for="Permissions[@i].GroupName" />

                                @if (Model.IsSystem)
                                {
                                    <input asp-for="Permissions[@i].IsSelected" class="form-check-input" disabled="disabled" />
                                }
                                else
                                {
                                    <input asp-for="Permissions[@i].IsSelected" class="form-check-input" />
                                }

                                <label asp-for="Permissions[@i].IsSelected" class="form-check-label fw-semibold">
                                    @Model.Permissions[i].DisplayName
                                </label>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mt-4 d-flex gap-2">
                @if (!Model.IsSystem)
                {
                    <button type="submit" class="btn btn-primary">Update Role</button>
                }
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}