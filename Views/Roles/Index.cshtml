@model List<GymSaaS.Models.RoleListItemViewModel>

@{
    ViewData["Title"] = "Roles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Roles</h2>
        <p class="text-muted mb-0">Manage system roles and their accessible views.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Create Role
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <h5>No roles found</h5>
                <p class="text-muted">Start by creating your first custom role.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Role Name</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th>Views</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@role.RoleName</td>
                                <td>@(string.IsNullOrWhiteSpace(role.RoleDescription) ? "-" : role.RoleDescription)</td>
                                <td>
                                    @if (role.IsSystem)
                                    {
                                        <span class="badge bg-dark">System</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Custom</span>
                                    }
                                </td>
                                <td>@role.ViewsCount</td>
                                <td>
                                    @if (role.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@role.RoleId" class="btn btn-sm btn-outline-secondary">
                                        Details
                                    </a>

                                    @if (!role.IsSystem)
                                    {
                                        <a asp-action="Edit" asp-route-id="@role.RoleId" class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>