@model List<GymSaaS.Models.RoleListItemViewModel>

@{
    ViewData["Title"] = "Roles";
    ViewData["Subtitle"] = "Access control";

    var systemCount = Model.Count(r => r.IsSystem);
    var customCount = Model.Count(r => !r.IsSystem);
    var activeCount = Model.Count(r => r.IsActive);
}

@section Styles {
<style>
    .roles-shell { max-width: 1100px; }

    /* Stat tiles */
    .roles-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }
    @@media (max-width: 700px) { .roles-stats { grid-template-columns: 1fr; } }

    .roles-stat {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: box-shadow .25s ease, transform .25s ease, border-color .25s ease;
        position: relative; overflow: hidden;
    }
    .roles-stat::after {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.9), transparent);
        pointer-events: none;
    }
    .roles-stat:hover {
        box-shadow: 0 4px 8px rgba(15,23,42,0.05), 0 12px 28px rgba(15,23,42,0.08);
        transform: translateY(-2px);
        border-color: rgba(15,23,42,0.10);
    }
    .stat-icon {
        width: 40px; height: 40px; border-radius: 12px;
        background: linear-gradient(135deg, var(--fire-soft), rgba(249,115,22,0.10));
        border: 1px solid var(--fire-border);
        display: flex; align-items: center; justify-content: center;
        font-size: 17px; color: var(--fire);
        flex-shrink: 0;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .stat-val {
        font-family: var(--font-display);
        font-size: 24px; font-weight: 800;
        color: var(--t1); line-height: 1;
    }
    .stat-lbl {
        font-size: 10.5px; font-weight: 700;
        letter-spacing: .1em; text-transform: uppercase;
        color: var(--t3);
        margin-top: 3px;
    }

    /* Roles grid */
    .roles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
        gap: 16px;
    }

    .role-card {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        padding: 18px 20px;
        display: flex; flex-direction: column;
        position: relative; overflow: hidden;
        transition: box-shadow .25s ease, transform .25s ease, border-color .25s ease;
    }
    .role-card::before {
        content: '';
        position: absolute; top: 0; left: 20px; right: 20px; height: 2px;
        background: linear-gradient(90deg, var(--fire), #fdba74, transparent);
        border-radius: 0 0 2px 2px;
        opacity: 0;
        transition: opacity .25s ease;
    }
    .role-card:hover {
        box-shadow: 0 4px 8px rgba(15,23,42,0.05), 0 14px 32px rgba(15,23,42,0.10);
        transform: translateY(-3px);
        border-color: rgba(15,23,42,0.10);
    }
    .role-card:hover::before { opacity: 1; }
    .role-card.system::before {
        background: linear-gradient(90deg, #475569, #94a3b8, transparent);
        opacity: 1;
    }

    .role-head {
        display: flex; align-items: flex-start; gap: 12px;
        margin-bottom: 12px;
    }
    .role-avatar {
        width: 42px; height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--fire-soft), rgba(249,115,22,0.12));
        border: 1px solid var(--fire-border);
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; color: var(--fire);
        flex-shrink: 0;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .role-card.system .role-avatar {
        background: linear-gradient(135deg, rgba(71,85,105,0.10), rgba(71,85,105,0.16));
        border-color: rgba(71,85,105,0.20);
        color: #475569;
    }

    .role-name {
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 800;
        letter-spacing: .02em;
        text-transform: uppercase;
        color: var(--t1);
        line-height: 1.1;
    }
    .role-desc {
        font-size: 12.5px;
        color: var(--t3);
        margin-top: 4px;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .role-pills {
        display: flex; gap: 6px; flex-wrap: wrap;
        margin: 12px 0;
    }
    .pill {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 9px;
        border-radius: 999px;
        font-size: 11px; font-weight: 700;
        border: 1px solid;
        line-height: 1.5;
    }
    .pill.system {
        background: rgba(71,85,105,0.08);
        color: #334155;
        border-color: rgba(71,85,105,0.20);
    }
    .pill.custom {
        background: var(--fire-soft);
        color: var(--fire-text);
        border-color: var(--fire-border);
    }
    .pill.active {
        background: rgba(22,163,74,0.08);
        color: #15803d;
        border-color: rgba(22,163,74,0.20);
    }
    .pill.inactive {
        background: rgba(220,38,38,0.08);
        color: #dc2626;
        border-color: rgba(220,38,38,0.20);
    }

    .views-count {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(15,23,42,0.04);
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 12px;
        padding: 8px 12px;
        font-size: 12.5px; font-weight: 600;
        color: var(--t2);
        margin-bottom: 14px;
    }
    .views-count strong {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 800;
        color: var(--t1);
    }

    .role-actions {
        margin-top: auto;
        padding-top: 12px;
        border-top: 1px solid rgba(15,23,42,0.05);
        display: flex; gap: 8px;
    }
    .role-actions a {
        flex: 1;
        padding: 7px 12px;
        border-radius: 10px;
        border: 1px solid rgba(15,23,42,0.08);
        background: #fff;
        font-size: 12.5px; font-weight: 700;
        color: var(--t2);
        text-align: center;
        cursor: pointer;
        text-decoration: none;
        transition: all .15s ease;
    }
    .role-actions a:hover {
        background: #fafafa;
        color: var(--t1);
        border-color: rgba(15,23,42,0.14);
    }
    .role-actions a.primary {
        background: linear-gradient(135deg, var(--fire), var(--fire-dim));
        color: #fff;
        border: none;
        box-shadow: 0 1px 2px rgba(249,115,22,0.30), 0 2px 6px rgba(249,115,22,0.18);
    }
    .role-actions a.primary:hover {
        box-shadow: 0 4px 10px rgba(249,115,22,0.32), 0 6px 14px rgba(249,115,22,0.20);
    }

    /* Empty state */
    .empty-state {
        grid-column: 1 / -1;
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        text-align: center;
        padding: 60px 24px;
    }
    .empty-state i {
        font-size: 44px;
        color: var(--fire);
        opacity: .4;
        display: block;
        margin-bottom: 14px;
    }
    .empty-state h3 {
        font-family: var(--font-display);
        font-size: 17px; font-weight: 800;
        text-transform: uppercase; letter-spacing: .03em;
        color: var(--t1);
        margin-bottom: 6px;
    }
    .empty-state p {
        color: var(--t3);
        font-size: 13px;
        margin-bottom: 20px;
    }
</style>
}

<div class="roles-shell">

    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
        <div>
            <h1 style="font-family:var(--font-display);font-size:22px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--t1);margin:0;">
                Roles &amp; Permissions
            </h1>
            <p style="font-size:13px;color:var(--t3);margin:3px 0 0;">Define which sections of the system each staff role can access</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Role
        </a>
    </div>

    <!-- Stats -->
    <div class="roles-stats">
        <div class="roles-stat">
            <div class="stat-icon"><i class="bi bi-shield-check"></i></div>
            <div>
                <div class="stat-val">@Model.Count</div>
                <div class="stat-lbl">Total Roles</div>
            </div>
        </div>
        <div class="roles-stat">
            <div class="stat-icon"><i class="bi bi-stars"></i></div>
            <div>
                <div class="stat-val">@customCount</div>
                <div class="stat-lbl">Custom Roles</div>
            </div>
        </div>
        <div class="roles-stat">
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
            <div>
                <div class="stat-val">@activeCount</div>
                <div class="stat-lbl">Active</div>
            </div>
        </div>
    </div>

    <!-- Cards -->
    <div class="roles-grid">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-shield-lock"></i>
                <h3>No roles yet</h3>
                <p>Create your first custom role to control staff access.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Create First Role
                </a>
            </div>
        }
        else
        {
            @foreach (var role in Model)
            {
                <div class="role-card @(role.IsSystem ? "system" : "")">
                    <div class="role-head">
                        <div class="role-avatar">
                            <i class="bi @(role.IsSystem ? "bi-shield-fill" : "bi-shield")"></i>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div class="role-name">@role.RoleName</div>
                            <div class="role-desc">@(string.IsNullOrWhiteSpace(role.RoleDescription) ? "No description provided" : role.RoleDescription)</div>
                        </div>
                    </div>

                    <div class="role-pills">
                        @if (role.IsSystem)
                        {
                            <span class="pill system"><i class="bi bi-lock-fill" style="font-size:9px;"></i> System</span>
                        }
                        else
                        {
                            <span class="pill custom"><i class="bi bi-pencil" style="font-size:9px;"></i> Custom</span>
                        }

                        @if (role.IsActive)
                        {
                            <span class="pill active">● Active</span>
                        }
                        else
                        {
                            <span class="pill inactive">● Inactive</span>
                        }
                    </div>

                    <div class="views-count">
                        <i class="bi bi-eye-fill" style="color:var(--fire);font-size:13px;"></i>
                        <span><strong>@role.ViewsCount</strong> @(role.ViewsCount == 1 ? "section" : "sections") accessible</span>
                    </div>

                    <div class="role-actions">
                        <a asp-action="Details" asp-route-id="@role.RoleId">
                            <i class="bi bi-eye"></i> View
                        </a>
                        @if (!role.IsSystem)
                        {
                            <a asp-action="Edit" asp-route-id="@role.RoleId" class="primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
