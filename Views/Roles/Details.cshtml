@model GymSaaS.Models.EditRoleViewModel
@using GymSaaS.Models

@{
    ViewData["Title"] = Model.RoleName;
    ViewData["Subtitle"] = "Role details";

    var selectedFolders = Model.Permissions
        .Where(x => x.IsSelected)
        .Select(p => new
        {
            Permission = p,
            Meta = ViewPermissionCatalog.Resolve(p.DisplayName)
        })
        .GroupBy(x => x.Meta.Group)
        .OrderBy(g => Array.IndexOf(ViewPermissionCatalog.GroupOrder, g.Key) < 0
            ? int.MaxValue
            : Array.IndexOf(ViewPermissionCatalog.GroupOrder, g.Key))
        .ToList();

    int totalSelected = Model.Permissions.Count(x => x.IsSelected);
    int totalAvailable = Model.Permissions.Count;
}

@section Styles {
<style>
    .details-shell { max-width: 920px; }

    .summary-card {
        background: linear-gradient(135deg, #ffffff 0%, #fbfbfd 100%);
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 6px 20px rgba(15,23,42,0.05);
        padding: 24px;
        margin-bottom: 18px;
        position: relative;
        overflow: hidden;
    }
    .summary-card::before {
        content: '';
        position: absolute;
        top: 0; left: 24px; right: 24px; height: 2px;
        background: linear-gradient(90deg, var(--fire), #fdba74, transparent);
        border-radius: 0 0 2px 2px;
    }
    .summary-card.system::before {
        background: linear-gradient(90deg, #475569, #94a3b8, transparent);
    }

    .summary-head {
        display: flex; align-items: flex-start; gap: 16px;
        margin-bottom: 18px;
    }
    .summary-avatar {
        width: 56px; height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--fire-soft), rgba(249,115,22,0.14));
        border: 1px solid var(--fire-border);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; color: var(--fire);
        flex-shrink: 0;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .summary-card.system .summary-avatar {
        background: linear-gradient(135deg, rgba(71,85,105,0.10), rgba(71,85,105,0.18));
        border-color: rgba(71,85,105,0.20);
        color: #475569;
    }
    .summary-info { flex: 1; min-width: 0; }
    .summary-name {
        font-family: var(--font-display);
        font-size: 22px; font-weight: 800;
        text-transform: uppercase; letter-spacing: .03em;
        color: var(--t1);
        line-height: 1.1;
        margin-bottom: 4px;
    }
    .summary-desc {
        font-size: 13.5px;
        color: var(--t2);
        line-height: 1.5;
    }
    .summary-desc.empty { color: var(--t4); font-style: italic; }
    .summary-actions { display: flex; gap: 8px; flex-shrink: 0; }

    .pills {
        display: flex; gap: 6px; flex-wrap: wrap;
        margin-bottom: 0;
    }
    .pill {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 4px 11px;
        border-radius: 999px;
        font-size: 11.5px; font-weight: 700;
        border: 1px solid;
        line-height: 1.5;
    }
    .pill.system  { background: rgba(71,85,105,.08); color: #334155; border-color: rgba(71,85,105,.20); }
    .pill.custom  { background: var(--fire-soft); color: var(--fire-text); border-color: var(--fire-border); }
    .pill.active  { background: rgba(22,163,74,.08); color: #15803d; border-color: rgba(22,163,74,.20); }
    .pill.inactive{ background: rgba(220,38,38,.08); color: #dc2626; border-color: rgba(220,38,38,.20); }

    /* Permissions display card */
    .perms-card {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.06);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04), 0 4px 14px rgba(15,23,42,0.04);
        overflow: hidden;
    }
    .perms-head {
        padding: 16px 20px;
        background: linear-gradient(to bottom, #fafafa, #f5f5f7);
        border-bottom: 1px solid rgba(15,23,42,0.05);
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px;
    }
    .perms-head-left { display: flex; align-items: center; gap: 12px; }
    .perms-ico {
        width: 32px; height: 32px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--fire-soft), rgba(249,115,22,0.12));
        border: 1px solid var(--fire-border);
        display: flex; align-items: center; justify-content: center;
        font-size: 15px; color: var(--fire);
    }
    .perms-title {
        font-family: var(--font-display);
        font-size: 13px; font-weight: 800;
        letter-spacing: .06em; text-transform: uppercase;
        color: var(--t1);
    }
    .perms-counter {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(15,23,42,0.05);
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 999px;
        padding: 5px 12px;
        font-size: 12px; font-weight: 700;
        color: var(--t2);
    }
    .perms-counter strong {
        font-family: var(--font-display);
        font-size: 14px;
        color: var(--fire);
    }

    .perms-body { padding: 20px; }

    .group-block { margin-bottom: 18px; }
    .group-block:last-child { margin-bottom: 0; }
    .group-block-title {
        font-family: var(--font-display);
        font-size: 11px; font-weight: 800;
        letter-spacing: .12em; text-transform: uppercase;
        color: var(--t3);
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(15,23,42,0.05);
        margin-bottom: 12px;
    }
    .perm-tags {
        display: flex; flex-wrap: wrap; gap: 8px;
    }
    .perm-tag {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 7px 12px;
        background: linear-gradient(135deg, var(--fire-soft), rgba(249,115,22,0.10));
        color: var(--fire-text);
        border: 1px solid var(--fire-border);
        border-radius: 10px;
        font-size: 12.5px;
        font-weight: 700;
        line-height: 1.4;
        box-shadow: 0 1px 2px rgba(249,115,22,0.06);
    }
    .perm-tag i { font-size: 13px; color: var(--fire); }

    .empty-perms {
        text-align: center;
        padding: 32px 20px;
        color: var(--t3);
    }
    .empty-perms i {
        font-size: 32px;
        display: block;
        margin-bottom: 12px;
        opacity: .4;
    }
</style>
}

<div class="details-shell">

    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--t2);margin-bottom:16px;">
        <i class="bi bi-arrow-left"></i> Back to Roles
    </a>

    <!-- Summary -->
    <div class="summary-card @(Model.IsSystem ? "system" : "")">

        <div class="summary-head">
            <div class="summary-avatar">
                <i class="bi @(Model.IsSystem ? "bi-shield-fill" : "bi-shield")"></i>
            </div>

            <div class="summary-info">
                <div class="summary-name">@Model.RoleName</div>
                <div class="summary-desc @(string.IsNullOrWhiteSpace(Model.RoleDescription) ? "empty" : "")">
                    @(string.IsNullOrWhiteSpace(Model.RoleDescription) ? "No description provided" : Model.RoleDescription)
                </div>
            </div>

            <div class="summary-actions">
                @if (!Model.IsSystem)
                {
                    <a asp-action="Edit" asp-route-id="@Model.RoleId" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit Role
                    </a>
                }
            </div>
        </div>

        <div class="pills">
            @if (Model.IsSystem)
            {
                <span class="pill system"><i class="bi bi-lock-fill" style="font-size:9px;"></i> Built-in Role</span>
            }
            else
            {
                <span class="pill custom"><i class="bi bi-pencil" style="font-size:9px;"></i> Custom Role</span>
            }

            @if (Model.IsActive)
            {
                <span class="pill active">● Active</span>
            }
            else
            {
                <span class="pill inactive">● Inactive</span>
            }
        </div>
    </div>

    <!-- Permissions -->
    <div class="perms-card">
        <div class="perms-head">
            <div class="perms-head-left">
                <div class="perms-ico"><i class="bi bi-eye-fill"></i></div>
                <div>
                    <div class="perms-title">Accessible Sections</div>
                </div>
            </div>
            <div class="perms-counter">
                <strong>@totalSelected</strong>
                <span>/ @totalAvailable available</span>
            </div>
        </div>

        <div class="perms-body">
            @if (!selectedFolders.Any())
            {
                <div class="empty-perms">
                    <i class="bi bi-folder-x"></i>
                    <div style="font-weight:700;color:var(--t2);margin-bottom:4px;">No sections assigned</div>
                    <div style="font-size:12.5px;">This role cannot access any pages of the system.</div>
                </div>
            }
            else
            {
                @foreach (var group in selectedFolders)
                {
                    <div class="group-block">
                        <div class="group-block-title">@group.Key</div>
                        <div class="perm-tags">
                            @foreach (var item in group)
                            {
                                <span class="perm-tag">
                                    <i class="bi @item.Meta.Icon"></i>
                                    @item.Meta.Label
                                </span>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
