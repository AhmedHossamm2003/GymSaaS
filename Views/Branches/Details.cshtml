@model GymSaaS.Models.BranchDetailsViewModel
@{
    ViewData["Title"] = Model.BranchName;
    ViewData["Subtitle"] = "Branch Details";
}

@section Styles {
    <style>
        .details-shell {
            max-width: 860px;
        }

        .details-hero {
            background: linear-gradient(135deg, #ffffff 0%, #fbfbfd 100%);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            padding: 26px;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 18px;
            flex-wrap: wrap;
            position: relative;
            overflow: hidden;
        }
            .details-hero::before {
                content: '';
                position: absolute;
                top: 0;
                left: 24px;
                right: 24px;
                height: 2px;
                background: linear-gradient(90deg, var(--fire), #fdba74, transparent);
                border-radius: 0 0 2px 2px;
            }

        .dh-icon {
            width: 56px;
            height: 56px;
            border-radius: var(--r-md);
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            color: var(--fire);
            flex-shrink: 0;
        }

        .dh-info {
            flex: 1;
            min-width: 200px;
        }

        .dh-name {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 800;
            letter-spacing: .02em;
            text-transform: uppercase;
            color: var(--t1);
            line-height: 1;
        }

        .dh-code {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--t3);
            margin-top: 5px;
        }

        .dh-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        /* Stats */
        .stat-row {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
            gap: 14px;
            margin-bottom: 16px;
        }

        /* Capacity progress bar inside stat card */
        .cap-bar-wrap {
            margin-top: 6px;
            height: 4px;
            background: var(--border);
            border-radius: 4px;
            overflow: hidden;
            width: 100%;
        }
        .cap-bar-fill {
            height: 100%;
            border-radius: 4px;
            background: var(--fire);
            transition: width .3s;
        }
        .cap-bar-fill.warn { background: var(--yellow); }
        .cap-bar-fill.full { background: var(--red); }

        .stat-item {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            position: relative;
            overflow: hidden;
            transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
        }
            .stat-item::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.9), transparent);
                pointer-events: none;
            }
            .stat-item:hover {
                box-shadow: var(--sh-md);
                transform: translateY(-2px);
                border-color: var(--border-strong);
            }

        .si-icon {
            width: 38px;
            height: 38px;
            border-radius: var(--r-sm);
            background: var(--surface-2);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            color: var(--fire);
        }

        .si-val {
            font-family: var(--font-display);
            font-size: 26px;
            font-weight: 800;
            color: var(--t1);
            line-height: 1;
        }

        .si-lbl {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t3);
            margin-top: 3px;
        }

        /* Info card */
        .info-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            overflow: hidden;
            margin-bottom: 18px;
            transition: box-shadow 0.25s ease, border-color 0.25s ease;
        }
            .info-card:hover {
                box-shadow: var(--sh-md);
                border-color: var(--border-strong);
            }

        .ic-head {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(to bottom, #fafafa, #f5f5f7);
        }

        .ic-head-icon {
            width: 28px;
            height: 28px;
            border-radius: var(--r-xs);
            background: var(--fire-soft);
            border: 1px solid var(--fire-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: var(--fire);
        }

        .ic-head-title {
            font-family: var(--font-display);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--t1);
        }

        .ic-body {
            padding: 20px;
        }

        .info-row {
            display: flex;
            align-items: flex-start;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            gap: 16px;
        }

            .info-row:last-child {
                border-bottom: none;
            }

        .info-key {
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: var(--t3);
            min-width: 160px;
            flex-shrink: 0;
        }

        .info-val {
            font-size: 13.5px;
            color: var(--t1);
            flex: 1;
        }

        /* QR card */
        .qr-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            box-shadow: var(--sh-sm);
            overflow: hidden;
            margin-bottom: 16px;
        }

        .qr-body {
            padding: 24px;
            display: flex;
            align-items: flex-start;
            gap: 28px;
            flex-wrap: wrap;
        }

        .qr-image-wrap {
            flex-shrink: 0;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: var(--r-md);
            padding: 12px;
            box-shadow: var(--sh-xs);
        }

            .qr-image-wrap img {
                width: 160px;
                height: 160px;
                display: block;
            }

        .qr-info {
            flex: 1;
            min-width: 200px;
        }

        .qr-value-box {
            background: var(--canvas);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 10px 14px;
            font-family: monospace;
            font-size: 12px;
            color: var(--t2);
            word-break: break-all;
            margin-bottom: 14px;
        }

        .qr-meta {
            font-size: 12px;
            color: var(--t3);
            margin-bottom: 16px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .qr-meta span {
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .qr-meta i {
                font-size: 12px;
            }

        .qr-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .no-qr-state {
            padding: 32px 24px;
            text-align: center;
        }

        .no-qr-icon {
            width: 52px;
            height: 52px;
            border-radius: var(--r-md);
            background: var(--yellow-bg);
            border: 1px solid var(--yellow-border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--yellow);
            margin: 0 auto 12px;
        }
    </style>
}

<!-- Back link -->
<div style="margin-bottom:20px;">
    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--t2);">
        <i class="bi bi-arrow-left" style="font-size:14px;"></i> Back to Branches
    </a>
</div>

<div class="details-shell">

    <!-- Hero -->
    <div class="details-hero">
        <div class="dh-icon"><i class="bi bi-building"></i></div>
        <div class="dh-info">
            <div class="dh-name">@Model.BranchName</div>
            <div class="dh-code">@Model.BranchCode</div>
            <div style="margin-top:8px; display:flex; gap:6px; flex-wrap:wrap;">
                @if (Model.IsActive)
                {
                    <span class="badge badge-active">Active</span>
                }
                else
                {
                    <span class="badge badge-inactive">Inactive</span>
                }
                @if (Model.HasQrCode)
                {
                    <span class="badge badge-info">QR v@(Model.QrVersionNo)</span>
                }
            </div>
        </div>
        <div class="dh-actions">
            <a asp-action="Edit" asp-route-id="@Model.BranchId" class="btn btn-secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <form asp-action="ToggleStatus" asp-route-id="@Model.BranchId" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="btn @(Model.IsActive ? "btn-danger" : "btn-secondary")"
                        onclick="return confirm('@(Model.IsActive ? "Deactivate" : "Activate") this branch?')">
                    <i class="bi bi-@(Model.IsActive ? "pause-circle" : "play-circle")"></i>
                    @(Model.IsActive ? "Deactivate" : "Activate")
                </button>
            </form>
        </div>
    </div>

    <!-- Stats -->
    <div class="stat-row">
        <div class="stat-item">
            <div class="si-icon"><i class="bi bi-people"></i></div>
            <div>
                <div class="si-val">@Model.MemberCount</div>
                <div class="si-lbl">Home Members</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="si-icon"><i class="bi bi-qr-code-scan"></i></div>
            <div>
                <div class="si-val">@Model.TodayCheckins</div>
                <div class="si-lbl">Check-ins Today</div>
            </div>
        </div>
        <div class="stat-item" style="border-top:2px solid var(--fire);">
            <div class="si-icon" style="background:var(--fire-soft);border-color:var(--fire-border);">
                <i class="bi bi-person-fill-check"></i>
            </div>
            <div style="flex:1;">
                <div class="si-val" style="color:var(--fire);">
                    @Model.InsideNow
                    @if (Model.Capacity.HasValue)
                    {
                        <span style="font-size:14px;font-weight:600;color:var(--t3);">/ @Model.Capacity</span>
                    }
                </div>
                <div class="si-lbl">Inside Right Now</div>
                @if (Model.Capacity.HasValue)
                {
                    var pct = Math.Min(100, (int)Math.Round(Model.InsideNow * 100.0 / Model.Capacity.Value));
                    var barClass = pct >= 100 ? "full" : pct >= 80 ? "warn" : "";
                    <div class="cap-bar-wrap">
                        <div class="cap-bar-fill @barClass" style="width:@pct%"></div>
                    </div>
                }
            </div>
        </div>
        @if (Model.Capacity.HasValue)
        {
            var pct = Math.Min(100, (int)Math.Round(Model.InsideNow * 100.0 / Model.Capacity.Value));
            var capColor = pct >= 100 ? "var(--red)" : pct >= 80 ? "var(--yellow)" : "var(--t1)";
            <div class="stat-item">
                <div class="si-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="si-val" style="color:@capColor;">@pct<span style="font-size:14px;font-weight:600;">%</span></div>
                    <div class="si-lbl">Capacity Used</div>
                </div>
            </div>
        }
    </div>

    <!-- QR Code -->
    <div class="qr-card">
        <div class="ic-head">
            <div class="ic-head-icon"><i class="bi bi-qr-code"></i></div>
            <span class="ic-head-title">Branch QR Code</span>
        </div>

        @if (Model.HasQrCode)
        {
            <div class="qr-body">

                <!-- QR Image -->
                <div class="qr-image-wrap">
                    <img src="@Url.Action("QrImage", "Branches", new { id = Model.BranchId })"
                         alt="QR Code for @Model.BranchName" />
                </div>

                <!-- QR Info -->
                <div class="qr-info">
                    <div style="font-size:13px;font-weight:600;color:var(--t1);margin-bottom:8px;">
                        Place this QR code at the branch entrance.
                    </div>
                    <div style="font-size:12.5px;color:var(--t2);margin-bottom:14px;line-height:1.6;">
                        Members scan this with their app to record attendance. Each branch has a unique QR.
                        Regenerating will invalidate the current QR immediately.
                    </div>

                    <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3);margin-bottom:6px;">
                        QR Value
                    </div>
                    <div class="qr-value-box">@Model.QrCodeValue</div>

                    <div class="qr-meta">
                        <span><i class="bi bi-layers"></i> Version @Model.QrVersionNo</span>
                        <span><i class="bi bi-calendar3"></i> Generated @Model.QrGeneratedAt?.ToString("MMM d, yyyy — h:mm tt") UTC</span>
                    </div>

                    <div class="qr-actions">
                        <a href="@Url.Action("QrImage", "Branches", new { id = Model.BranchId })"
                           download="QR-@(Model.BranchCode)-v@(Model.QrVersionNo).png"
                           class="btn btn-primary">
                            <i class="bi bi-download"></i> Download QR
                        </a>
                        <form asp-action="RegenerateQr" asp-route-id="@Model.BranchId" method="post" style="margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-danger"
                                    onclick="return confirm('Regenerating will invalidate the current QR. All printed copies will stop working. Continue?')">
                                <i class="bi bi-arrow-clockwise"></i> Regenerate QR
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        }
        else
        {
            <div class="no-qr-state">
                <div class="no-qr-icon"><i class="bi bi-exclamation-triangle"></i></div>
                <div style="font-size:14px;font-weight:600;color:var(--t1);margin-bottom:6px;">No QR Code Found</div>
                <div style="font-size:13px;color:var(--t2);margin-bottom:16px;">
                    This branch doesn't have an active QR code yet.
                </div>
                <form asp-action="RegenerateQr" asp-route-id="@Model.BranchId" method="post" style="margin:0;display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-qr-code"></i> Generate QR Code
                    </button>
                </form>
            </div>
        }
    </div>

    <!-- Location -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-icon"><i class="bi bi-geo-alt"></i></div>
            <span class="ic-head-title">Location</span>
        </div>
        <div class="ic-body">
            <div class="info-row">
                <span class="info-key">Address</span>
                <span class="info-val">
                    @if (!string.IsNullOrWhiteSpace(Model.FullAddress))
                    {
                        @Model.FullAddress
                    }
                    else
                    {
                        <span style="color:var(--t3);">Not provided</span>
                    }
                </span>
            </div>
            <div class="info-row">
                <span class="info-key">City</span>
                <span class="info-val">@(Model.City ?? "—")</span>
            </div>
            <div class="info-row">
                <span class="info-key">Country</span>
                <span class="info-val">@(Model.Country ?? "—")</span>
            </div>
        </div>
    </div>

    <!-- Contact -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-icon"><i class="bi bi-telephone"></i></div>
            <span class="ic-head-title">Contact</span>
        </div>
        <div class="ic-body">
            <div class="info-row">
                <span class="info-key">Phone</span>
                <span class="info-val">
                    @if (!string.IsNullOrWhiteSpace(Model.ContactPhone))
                    {
                        <a href="tel:@Model.ContactPhone" style="color:var(--fire);">@Model.ContactPhone</a>
                    }
                    else
                    {
                        <span style="color:var(--t3);">Not provided</span>
                    }
                </span>
            </div>
            <div class="info-row">
                <span class="info-key">Email</span>
                <span class="info-val">
                    @if (!string.IsNullOrWhiteSpace(Model.ContactEmail))
                    {
                        <a href="mailto:@Model.ContactEmail" style="color:var(--fire);">@Model.ContactEmail</a>
                    }
                    else
                    {
                        <span style="color:var(--t3);">Not provided</span>
                    }
                </span>
            </div>
        </div>
    </div>

    <!-- Settings -->
    <div class="info-card">
        <div class="ic-head">
            <div class="ic-head-icon"><i class="bi bi-sliders"></i></div>
            <span class="ic-head-title">Settings & Info</span>
        </div>
        <div class="ic-body">
            <div class="info-row">
                <span class="info-key">Presence Window</span>
                <span class="info-val">
                    @Model.MemberPresenceWindowMinutes minutes
                    <span style="font-size:12px;color:var(--t3);margin-left:6px;">(members counted as inside for this duration)</span>
                </span>
            </div>
            <div class="info-row">
                <span class="info-key">Max Capacity</span>
                <span class="info-val">
                    @if (Model.Capacity.HasValue)
                    {
                        @Model.Capacity.Value
                        <span style="font-size:12px;color:var(--t3);margin-left:6px;">members max at once</span>
                    }
                    else
                    {
                        <span style="color:var(--t3);">Unlimited</span>
                    }
                </span>
            </div>
            <div class="info-row">
                <span class="info-key">Created</span>
                <span class="info-val">@Model.CreatedAtUtc.ToString("MMMM d, yyyy — h:mm tt") UTC</span>
            </div>
            @if (Model.UpdatedAtUtc.HasValue)
            {
                <div class="info-row">
                    <span class="info-key">Last Updated</span>
                    <span class="info-val">@Model.UpdatedAtUtc.Value.ToString("MMMM d, yyyy — h:mm tt") UTC</span>
                </div>
            }
        </div>
    </div>

</div>
