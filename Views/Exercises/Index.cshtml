@model List<GymSaaS.Models.ExerciseListItem>
@using GymSaaS.Persistence.Entities

@{
    var search     = ViewData["Search"] as string;
    var categoryId = ViewData["CategoryId"] as int?;
    var difficulty = ViewData["Difficulty"] as byte?;
    var categories = ViewData["Categories"] as List<ExerciseCategory> ?? new();
    var total      = (int)(ViewData["TotalCount"] ?? 0);
    var active     = (int)(ViewData["ActiveCount"] ?? 0);
}

<!-- Page header -->
<div class="page-header">
    <div>
        <div class="page-title">Exercise Library</div>
        <div class="page-subtitle">Browse and manage the exercise catalog</div>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-controller="Exercises" asp-action="QuickMediaEdit" class="btn btn-secondary">
            <i class="bi bi-camera-video"></i> Add Videos
        </a>
        <form asp-controller="Exercises" asp-action="SeedDefault" method="post"
              onsubmit="return confirm('Load all default exercises into your library?\n\nExercises that already exist will be skipped.')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-secondary">
                <i class="bi bi-cloud-download"></i> Load Default Exercises
            </button>
        </form>
        <a asp-controller="Exercises" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Exercise
        </a>
    </div>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:24px">
    <div class="stat-card highlight">
        <div class="stat-icon"><i class="bi bi-activity"></i></div>
        <div>
            <div class="stat-value">@total</div>
            <div class="stat-label">Total Exercises</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        <div>
            <div class="stat-value">@active</div>
            <div class="stat-label">Active</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
        <div>
            <div class="stat-value">@(total - active)</div>
            <div class="stat-label">Inactive</div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom:20px;padding:16px 20px">
    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <div style="flex:1;min-width:200px;display:flex;align-items:center;gap:8px;background:var(--bg-raised);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0 12px">
            <i class="bi bi-search" style="color:var(--text-faint);font-size:13px"></i>
            <input type="text" name="search" value="@search" placeholder="Search by name or equipment…"
                   style="border:none;background:transparent;outline:none;padding:8px 0;font-size:13px;width:100%"/>
        </div>

        <select name="categoryId" style="min-width:160px">
            <option value="">All Categories</option>
            @foreach (var c in categories)
            {
                <option value="@c.ExerciseCategoryId" selected="@(categoryId == c.ExerciseCategoryId)">@c.CategoryName</option>
            }
        </select>

        <select name="difficulty" style="min-width:140px">
            <option value="">All Levels</option>
            <option value="1" selected="@(difficulty == 1)">Beginner</option>
            <option value="2" selected="@(difficulty == 2)">Intermediate</option>
            <option value="3" selected="@(difficulty == 3)">Advanced</option>
        </select>

        <button type="submit" class="btn btn-secondary"><i class="bi bi-funnel"></i> Filter</button>
        @if (!string.IsNullOrWhiteSpace(search) || categoryId.HasValue || difficulty.HasValue)
        {
            <a asp-controller="Exercises" asp-action="Index" class="btn btn-ghost">Clear</a>
        }
    </form>
</div>

<!-- Exercise cards -->
@if (!Model.Any())
{
    <div class="card" style="text-align:center;padding:60px 24px">
        <i class="bi bi-activity" style="font-size:40px;color:var(--text-faint)"></i>
        <div style="margin-top:12px;color:var(--text-muted);font-size:14px">No exercises found.</div>
        <a asp-controller="Exercises" asp-action="Create" class="btn btn-primary" style="margin-top:16px;display:inline-flex">
            <i class="bi bi-plus-lg"></i> Add First Exercise
        </a>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px">
        @foreach (var e in Model)
        {
            <div class="card" style="padding:0;display:flex;flex-direction:column;overflow:hidden">

                <!-- Media area: YouTube thumbnail OR photo OR icon -->
                @if (e.VideoThumbnailUrl != null)
                {
                    <!-- YouTube thumbnail with play button -->
                    <div style="position:relative;aspect-ratio:16/9;cursor:pointer;flex-shrink:0"
                         onclick="openVideo('@e.EmbedUrl')" title="Watch demo">
                        <img src="@e.VideoThumbnailUrl" alt="@e.ExerciseName demo"
                             style="width:100%;height:100%;object-fit:cover;display:block"/>
                        <div style="position:absolute;inset:0;background:rgba(0,0,0,.28);display:flex;align-items:center;justify-content:center;transition:background .15s"
                             onmouseenter="this.style.background='rgba(0,0,0,.4)'" onmouseleave="this.style.background='rgba(0,0,0,.28)'">
                            <div style="width:52px;height:52px;background:#ff0000e6;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px rgba(0,0,0,.4)">
                                <i class="bi bi-play-fill" style="color:#fff;font-size:22px;margin-left:3px"></i>
                            </div>
                        </div>
                    </div>
                }
                else if (e.IsVimeo)
                {
                    <!-- Vimeo (no thumbnail available without API) -->
                    <div style="position:relative;aspect-ratio:16/9;background:linear-gradient(135deg,#1ab7ea20,#1ab7ea08);border-bottom:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0"
                         onclick="openVideo('@e.EmbedUrl')" title="Watch demo">
                        <div style="text-align:center">
                            <div style="width:52px;height:52px;background:#1ab7ea;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 8px">
                                <i class="bi bi-play-fill" style="color:#fff;font-size:22px;margin-left:3px"></i>
                            </div>
                            <div style="font-size:11px;color:var(--text-faint)">Watch on Vimeo</div>
                        </div>
                    </div>
                }

                <div style="padding:16px 16px 0;display:flex;flex-direction:column;gap:12px;flex:1">

                    <!-- Header: photo/icon + name + status -->
                    <div style="display:flex;align-items:center;gap:12px">
                        @if (!string.IsNullOrEmpty(e.PhotoUrl))
                        {
                            <img src="@e.PhotoUrl" alt="@e.ExerciseName"
                                 style="width:44px;height:44px;border-radius:8px;object-fit:cover;flex-shrink:0"/>
                        }
                        else if (!e.HasVideo)
                        {
                            <div style="width:44px;height:44px;border-radius:8px;background:var(--bg-raised);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--border)">
                                <i class="bi @(e.CategoryIconClass ?? "bi-activity")" style="font-size:20px;color:var(--orange)"></i>
                            </div>
                        }
                        <div style="min-width:0;flex:1">
                            <div style="font-weight:700;font-size:14px;color:var(--black);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@e.ExerciseName</div>
                            <div style="font-size:11.5px;color:var(--text-secondary);margin-top:1px">@e.CategoryName</div>
                        </div>
                        <span class="badge @(e.IsActive ? "badge-active" : "badge-inactive")" style="flex-shrink:0">
                            @(e.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>

                    <!-- Difficulty + equipment badges -->
                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                        <span style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;background:@(e.DifficultyColor)1a;color:@e.DifficultyColor;border:1px solid @(e.DifficultyColor)40">
                            @e.DifficultyLabel
                        </span>
                        @if (!string.IsNullOrEmpty(e.Equipment))
                        {
                            <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:var(--bg-raised);color:var(--text-secondary);border:1px solid var(--border)">
                                <i class="bi bi-tools" style="font-size:10px"></i> @e.Equipment
                            </span>
                        }
                        @if (e.HasVideo)
                        {
                            <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:#ff000010;color:#cc0000;border:1px solid #ff000030;cursor:pointer"
                                  onclick="openVideo('@e.EmbedUrl')">
                                <i class="bi bi-play-circle" style="font-size:10px"></i> Video
                            </span>
                        }
                    </div>

                    <!-- Muscle chips -->
                    @if (e.MuscleGroupNames.Any())
                    {
                        <div style="display:flex;gap:5px;flex-wrap:wrap">
                            @foreach (var mg in e.MuscleGroupNames.Take(4))
                            {
                                <span style="font-size:10.5px;padding:2px 8px;border-radius:4px;background:var(--orange)15;color:var(--orange);font-weight:600">@mg</span>
                            }
                            @if (e.MuscleGroupNames.Count > 4)
                            {
                                <span style="font-size:10.5px;padding:2px 8px;border-radius:4px;background:var(--bg-raised);color:var(--text-faint)">+@(e.MuscleGroupNames.Count - 4)</span>
                            }
                        </div>
                    }

                </div>

                <!-- Actions -->
                <div style="display:flex;gap:8px;border-top:1px solid var(--border);padding:12px 16px;margin-top:12px">
                    <a asp-controller="Exercises" asp-action="Edit" asp-route-id="@e.ExerciseId"
                       class="btn btn-secondary" style="flex:1;justify-content:center;font-size:12px">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form asp-controller="Exercises" asp-action="Delete" asp-route-id="@e.ExerciseId"
                          method="post" onsubmit="return confirm('Remove \'@e.ExerciseName\'?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" style="font-size:12px">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>

            </div>
        }
    </div>
}

<!-- Video modal -->
<div id="videoModal"
     style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.82);align-items:center;justify-content:center;padding:20px"
     onclick="if(event.target===this)closeVideo()">
    <div style="position:relative;width:min(840px,100%)">
        <button onclick="closeVideo()"
                style="position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:28px;cursor:pointer;line-height:1;padding:4px 8px">
            &times;
        </button>
        <div style="aspect-ratio:16/9;border-radius:10px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,.6)">
            <iframe id="videoFrame" src="" allowfullscreen
                    style="width:100%;height:100%;border:none;display:block"></iframe>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openVideo(embedUrl) {
    document.getElementById('videoFrame').src = embedUrl;
    const modal = document.getElementById('videoModal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}
function closeVideo() {
    document.getElementById('videoFrame').src = '';
    document.getElementById('videoModal').style.display = 'none';
    document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeVideo(); });
</script>
}
