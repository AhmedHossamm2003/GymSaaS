@model List<GymSaaS.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Users</h2>
        <p class="text-muted mb-0">Manage system users, roles, and branch assignments.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Create User
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <h5>No users found</h5>
                <p class="text-muted">Start by creating your first user.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Branch</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@user.RoleName</td>
                                <td>@(string.IsNullOrWhiteSpace(user.BranchName) ? "-" : user.BranchName)</td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-secondary">
                                        Details
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>